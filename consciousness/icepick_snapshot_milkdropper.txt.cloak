----- FILE: ./crates/milkdropper-preset/src/context.rs -----
//! Variable context for preset execution.
//!
//! This module manages all variables accessible to preset expressions:
//! - Audio input variables (bass, mid, treb, etc.)
//! - User variables (q1-q32, t1-t8)
//! - Preset parameters (zoom, rot, cx, cy, etc.)
//! - Built-in variables (time, frame, fps)
//!
//! The context uses a dual representation:
//! - Named fields (bass, q[0], etc.) for easy Rust API access
//! - Flat array for fast indexed VM access
//!
//! This design allows O(1) variable access during bytecode execution
//! while maintaining a clean, ergonomic API for the user.

use std::fmt;

/// Variable index into the flat variable array.
///
/// This is used by the bytecode VM for fast variable access.
/// The index directly maps to a position in PresetContext::vars.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct VarIndex(pub(crate) u16);

impl fmt::Display for VarIndex {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "VarIndex({})", self.0)
    }
}

// ============================================================================
// Variable Index Constants
// ============================================================================
//
// These are compile-time constants that map variable names to indices.
// The layout is carefully designed for cache locality:
// - Audio vars first (read every frame)
// - User vars next (read/write frequently)
// - Built-ins last (read occasionally)

// Audio input variables (indices 0-5)
pub const BASS_INDEX: VarIndex = VarIndex(0);
pub const MID_INDEX: VarIndex = VarIndex(1);
pub const TREB_INDEX: VarIndex = VarIndex(2);
pub const BASS_ATT_INDEX: VarIndex = VarIndex(3);
pub const MID_ATT_INDEX: VarIndex = VarIndex(4);
pub const TREB_ATT_INDEX: VarIndex = VarIndex(5);

// User variables: q1-q32 (indices 6-37)
#[allow(dead_code)] // Used in tests
pub const Q1_INDEX: VarIndex = VarIndex(6);
// q2 = 7, q3 = 8, ... q32 = 37

// User variables: t1-t8 (indices 38-45)
#[allow(dead_code)] // Phase 2
pub const T1_INDEX: VarIndex = VarIndex(38);
// t2 = 39, t3 = 40, ... t8 = 45

// Built-in time variables (indices 46-48)
pub const TIME_INDEX: VarIndex = VarIndex(46);
pub const FRAME_INDEX: VarIndex = VarIndex(47);
pub const FPS_INDEX: VarIndex = VarIndex(48);

// Preset parameters (indices 49+)
// These are the core variables that affect rendering
pub const ZOOM_INDEX: VarIndex = VarIndex(49);
pub const ROT_INDEX: VarIndex = VarIndex(50);
pub const CX_INDEX: VarIndex = VarIndex(51);
pub const CY_INDEX: VarIndex = VarIndex(52);
pub const DX_INDEX: VarIndex = VarIndex(53);
pub const DY_INDEX: VarIndex = VarIndex(54);
pub const WARP_INDEX: VarIndex = VarIndex(55);
pub const SX_INDEX: VarIndex = VarIndex(56);
pub const SY_INDEX: VarIndex = VarIndex(57);

// Wave color parameters (indices 58-62)
pub const WAVE_R_INDEX: VarIndex = VarIndex(58);
pub const WAVE_G_INDEX: VarIndex = VarIndex(59);
pub const WAVE_B_INDEX: VarIndex = VarIndex(60);
pub const WAVE_X_INDEX: VarIndex = VarIndex(61);
pub const WAVE_Y_INDEX: VarIndex = VarIndex(62);

// Total number of variables
const VAR_COUNT: usize = 63;

/// Preset variable context.
///
/// This structure holds all variables that can be accessed by preset expressions.
/// It uses a dual representation for optimal performance and ergonomics.
///
/// ## Usage
///
/// ```rust
/// use milkdropper_preset::PresetContext;
///
/// // Create context
/// let mut ctx = PresetContext::new();
///
/// // Inject audio data (every frame)
/// ctx.bass = 0.8;
/// ctx.mid = 0.5;
/// ctx.treb = 0.3;
/// ctx.time = 1.5;
///
/// // Sync to internal array (before VM execution)
/// ctx.sync_to_array();
///
/// // ... VM executes, modifies vars[6..38] (q1-q32) ...
///
/// // Sync back to named fields (after VM execution)
/// ctx.sync_from_array();
///
/// // Access computed values
/// let zoom = 1.0 + ctx.q[0] * 0.1;  // q1 affects zoom
/// ```
#[derive(Debug, Clone)]
pub struct PresetContext {
    // === Audio Input Variables (Read-Only from Expressions) ===
    //
    // These are injected every frame from the Phoenix Marine audio analyzer.
    // Expressions can read but not write these (enforced at compile time).
    /// Bass frequency energy (0.0-1.0+)
    pub bass: f32,
    /// Mid frequency energy (0.0-1.0+)
    pub mid: f32,
    /// Treble frequency energy (0.0-1.0+)
    pub treb: f32,
    /// Bass attenuated (smoothed) energy (0.0-1.0+)
    pub bass_att: f32,
    /// Mid attenuated (smoothed) energy (0.0-1.0+)
    pub mid_att: f32,
    /// Treble attenuated (smoothed) energy (0.0-1.0+)
    pub treb_att: f32,

    // === User Variables (Read/Write from Expressions) ===
    //
    // These are persistent across frames and can be freely manipulated.
    /// User variables q1-q32 (general purpose)
    pub q: [f32; 32],
    /// User variables t1-t8 (historically "temporary", but also persistent)
    pub t: [f32; 8],

    // === Built-in Variables (Read-Only from Expressions) ===
    //
    /// Elapsed time in seconds since visualization start
    pub time: f32,
    /// Frame counter (incremented each frame)
    pub frame: u32,
    /// Frames per second (average)
    pub fps: f32,

    // === Preset Parameters (Read/Write from Expressions) ===
    //
    // These control the rendering behavior and are manipulated by
    // per-frame expressions to create animations.
    //
    /// Zoom amount (1.0 = normal, >1.0 = zoom in, <1.0 = zoom out)
    pub zoom: f32,
    /// Rotation angle in radians
    pub rot: f32,
    /// Center X coordinate (0.0-1.0)
    pub cx: f32,
    /// Center Y coordinate (0.0-1.0)
    pub cy: f32,
    /// Delta X translation
    pub dx: f32,
    /// Delta Y translation
    pub dy: f32,
    /// Warp amount (0.0 = none, 1.0+ = more warp)
    pub warp: f32,
    /// Stretch X factor
    pub sx: f32,
    /// Stretch Y factor
    pub sy: f32,

    // === Wave Parameters ===
    //
    /// Wave red color (0.0-1.0)
    pub wave_r: f32,
    /// Wave green color (0.0-1.0)
    pub wave_g: f32,
    /// Wave blue color (0.0-1.0)
    pub wave_b: f32,
    /// Wave X position (0.0-1.0)
    pub wave_x: f32,
    /// Wave Y position (0.0-1.0)
    pub wave_y: f32,

    // === Internal Flat Array for VM Access ===
    //
    // This is the actual storage used by the VM. It's kept in sync with
    // the named fields via sync_to_array() and sync_from_array().
    // Index layout: [bass, mid, treb, bass_att, mid_att, treb_att, q1..q32, t1..t8, time, frame, fps, zoom, rot, ...]
    pub(crate) vars: Vec<f32>,
}

impl PresetContext {
    /// Create a new preset context with default values.
    ///
    /// All variables are initialized to sensible defaults:
    /// - Audio variables: 0.0
    /// - User variables (q, t): 0.0
    /// - Time/frame/fps: 0.0/0/60.0
    /// - Preset parameters: Standard defaults (zoom=1.0, rot=0.0, etc.)
    pub fn new() -> Self {
        Self {
            // Audio inputs (will be injected each frame)
            bass: 0.0,
            mid: 0.0,
            treb: 0.0,
            bass_att: 0.0,
            mid_att: 0.0,
            treb_att: 0.0,

            // User variables
            q: [0.0; 32],
            t: [0.0; 8],

            // Built-ins
            time: 0.0,
            frame: 0,
            fps: 60.0,

            // Preset parameters (defaults from .milk spec)
            zoom: 1.0,
            rot: 0.0,
            cx: 0.5,
            cy: 0.5,
            dx: 0.0,
            dy: 0.0,
            warp: 1.0,
            sx: 1.0,
            sy: 1.0,

            // Wave parameters
            wave_r: 0.5,
            wave_g: 0.5,
            wave_b: 0.5,
            wave_x: 0.5,
            wave_y: 0.5,

            // Flat array (initialized below)
            vars: vec![0.0; VAR_COUNT],
        }
    }

    /// Synchronize named fields to internal flat array.
    ///
    /// Call this **before** VM execution to ensure the VM sees
    /// the latest values from Rust code.
    ///
    /// This is a cheap operation (~63 array assignments, <1μs).
    pub fn sync_to_array(&mut self) {
        // Audio inputs (indices 0-5)
        self.vars[0] = self.bass;
        self.vars[1] = self.mid;
        self.vars[2] = self.treb;
        self.vars[3] = self.bass_att;
        self.vars[4] = self.mid_att;
        self.vars[5] = self.treb_att;

        // User variables q1-q32 (indices 6-37)
        for i in 0..32 {
            self.vars[6 + i] = self.q[i];
        }

        // User variables t1-t8 (indices 38-45)
        for i in 0..8 {
            self.vars[38 + i] = self.t[i];
        }

        // Built-ins (indices 46-48)
        self.vars[46] = self.time;
        self.vars[47] = self.frame as f32;
        self.vars[48] = self.fps;

        // Preset parameters (indices 49-57)
        self.vars[49] = self.zoom;
        self.vars[50] = self.rot;
        self.vars[51] = self.cx;
        self.vars[52] = self.cy;
        self.vars[53] = self.dx;
        self.vars[54] = self.dy;
        self.vars[55] = self.warp;
        self.vars[56] = self.sx;
        self.vars[57] = self.sy;

        // Wave parameters (indices 58-62)
        self.vars[58] = self.wave_r;
        self.vars[59] = self.wave_g;
        self.vars[60] = self.wave_b;
        self.vars[61] = self.wave_x;
        self.vars[62] = self.wave_y;
    }

    /// Synchronize internal flat array back to named fields.
    ///
    /// Call this **after** VM execution to get the updated
    /// variable values back into Rust structs.
    ///
    /// Note: Audio input and built-in variables are NOT synced back
    /// since they are read-only from the expression's perspective.
    pub fn sync_from_array(&mut self) {
        // Audio inputs are read-only, don't sync back

        // User variables q1-q32 (indices 6-37)
        for i in 0..32 {
            self.q[i] = self.vars[6 + i];
        }

        // User variables t1-t8 (indices 38-45)
        for i in 0..8 {
            self.t[i] = self.vars[38 + i];
        }

        // Built-ins are read-only, don't sync back

        // Preset parameters (indices 49-57)
        self.zoom = self.vars[49];
        self.rot = self.vars[50];
        self.cx = self.vars[51];
        self.cy = self.vars[52];
        self.dx = self.vars[53];
        self.dy = self.vars[54];
        self.warp = self.vars[55];
        self.sx = self.vars[56];
        self.sy = self.vars[57];

        // Wave parameters (indices 58-62)
        self.wave_r = self.vars[58];
        self.wave_g = self.vars[59];
        self.wave_b = self.vars[60];
        self.wave_x = self.vars[61];
        self.wave_y = self.vars[62];
    }

    /// Get variable value by index (used by VM).
    ///
    /// Returns an error if the index is out of bounds.
    #[inline]
    pub(crate) fn get_var(&self, idx: VarIndex) -> Result<f32, crate::error::VMError> {
        self.vars
            .get(idx.0 as usize)
            .copied()
            .ok_or(crate::error::VMError::InvalidVariableIndex(idx))
    }

    /// Set variable value by index (used by VM).
    ///
    /// Returns an error if the index is out of bounds.
    #[inline]
    pub(crate) fn set_var(&mut self, idx: VarIndex, val: f32) -> Result<(), crate::error::VMError> {
        if let Some(slot) = self.vars.get_mut(idx.0 as usize) {
            *slot = val;
            Ok(())
        } else {
            Err(crate::error::VMError::InvalidVariableIndex(idx))
        }
    }

    /// Helper: Get Q variable index (q1 = index 0, q2 = index 1, etc.)
    ///
    /// Returns None if index is out of range (valid: 1-32)
    #[allow(dead_code)] // Phase 2
    pub(crate) fn q_index(num: u8) -> Option<VarIndex> {
        if (1..=32).contains(&num) {
            Some(VarIndex(5 + num as u16)) // q1 starts at index 6
        } else {
            None
        }
    }

    /// Helper: Get T variable index (t1 = index 0, t2 = index 1, etc.)
    ///
    /// Returns None if index is out of range (valid: 1-8)
    #[allow(dead_code)] // Phase 2
    pub(crate) fn t_index(num: u8) -> Option<VarIndex> {
        if (1..=8).contains(&num) {
            Some(VarIndex(37 + num as u16)) // t1 starts at index 38
        } else {
            None
        }
    }
}

impl Default for PresetContext {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_context_creation() {
        let ctx = PresetContext::new();
        assert_eq!(ctx.bass, 0.0);
        assert_eq!(ctx.zoom, 1.0);
        assert_eq!(ctx.cx, 0.5);
        assert_eq!(ctx.q[0], 0.0);
        assert_eq!(ctx.vars.len(), VAR_COUNT);
    }

    #[test]
    fn test_sync_to_array() {
        let mut ctx = PresetContext::new();
        ctx.bass = 0.8;
        ctx.mid = 0.5;
        ctx.q[0] = 1.5;
        ctx.zoom = 1.2;

        ctx.sync_to_array();

        assert_eq!(ctx.vars[0], 0.8); // bass
        assert_eq!(ctx.vars[1], 0.5); // mid
        assert_eq!(ctx.vars[6], 1.5); // q1
        assert_eq!(ctx.vars[49], 1.2); // zoom
    }

    #[test]
    fn test_sync_from_array() {
        let mut ctx = PresetContext::new();
        ctx.vars[6] = 2.5; // q1
        ctx.vars[49] = 1.5; // zoom

        ctx.sync_from_array();

        assert_eq!(ctx.q[0], 2.5);
        assert_eq!(ctx.zoom, 1.5);
    }

    #[test]
    fn test_get_set_var() {
        let mut ctx = PresetContext::new();
        ctx.sync_to_array();

        // Get bass (index 0)
        assert_eq!(ctx.get_var(BASS_INDEX).unwrap(), 0.0);

        // Set q1 (index 6)
        ctx.set_var(Q1_INDEX, 3.14).unwrap();
        assert_eq!(ctx.get_var(Q1_INDEX).unwrap(), 3.14);

        // Invalid index
        assert!(ctx.get_var(VarIndex(9999)).is_err());
    }

    #[test]
    fn test_q_index() {
        assert_eq!(PresetContext::q_index(1), Some(VarIndex(6)));
        assert_eq!(PresetContext::q_index(32), Some(VarIndex(37)));
        assert_eq!(PresetContext::q_index(0), None);
        assert_eq!(PresetContext::q_index(33), None);
    }

    #[test]
    fn test_t_index() {
        assert_eq!(PresetContext::t_index(1), Some(VarIndex(38)));
        assert_eq!(PresetContext::t_index(8), Some(VarIndex(45)));
        assert_eq!(PresetContext::t_index(0), None);
        assert_eq!(PresetContext::t_index(9), None);
    }
}

