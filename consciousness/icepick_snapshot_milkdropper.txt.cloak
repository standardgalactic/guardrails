│   │   └── software.rs  # Software rasterizer (CPU)
│   │
│   ├── primitives/      # Drawing primitives
│   │   ├── mod.rs
│   │   ├── waveform.rs  # Waveform rendering
│   │   ├── shapes.rs    # Custom shapes
│   │   └── sprites.rs   # Sprite rendering
│   │
│   ├── effects/         # Visual effects
│   │   ├── mod.rs
│   │   ├── warp.rs      # Warp shader effects
│   │   ├── blur.rs      # Motion blur
│   │   └── composite.rs # Compositing
│   │
│   ├── shaders/         # Shader management
│   │   ├── mod.rs
│   │   ├── wgsl.rs      # WGSL shader compilation
│   │   └── cache.rs     # Shader caching
│   │
│   └── util/
│       ├── mod.rs
│       ├── texture.rs   # Texture pool
│       └── color.rs     # Color utilities
│
├── tests/
│   └── render_test.rs
│
└── benches/
    └── render_bench.rs
```

**Dependencies**:
```toml
[dependencies]
log = "0.4"
thiserror = "1.0"

# GPU rendering
wgpu = { version = "0.18", optional = true }
bytemuck = { version = "1.14", optional = true }

# Software rendering
tiny-skia = { version = "0.11", optional = true }

# Utilities
glam = "0.25"            # Math (vectors, matrices)

[features]
default = ["wgpu-backend"]
wgpu-backend = ["wgpu", "bytemuck"]
software-backend = ["tiny-skia"]
```

**Key Implementation Notes**:
- **Backend abstraction** - Easy to swap wgpu for other APIs
- **Optional GPU** - Software fallback for headless/testing
- **Shader conversion** - HLSL → WGSL (manual or automated?)

