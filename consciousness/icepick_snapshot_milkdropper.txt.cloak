//! Built-in math functions for expression language.
//!
//! This module defines all the built-in functions that can be called
//! from preset expressions: sin, cos, sqrt, abs, etc.
//!
//! ## Phase 1 Functions (MVP)
//! - sin(x), cos(x) - Trigonometry
//! - sqrt(x), abs(x) - Basic math
//!
//! ## Phase 2 Functions (Later)
//! - pow(base, exp), exp(x), log(x)
//! - tan(x), atan(x), atan2(y, x)
//! - min(a, b), max(a, b), clamp(x, min, max)
//! - rand(), rand(max)

use crate::error::VMError;
use crate::eval::bytecode::Instruction;

/// Built-in function enum.
///
/// Each variant represents a function that can be called from expressions.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum BuiltinFunc {
    // === Phase 1: MVP Functions ===
    /// sin(x) - Sine
    Sin,

    /// cos(x) - Cosine
    Cos,

    /// sqrt(x) - Square root
    Sqrt,

    /// abs(x) - Absolute value
    Abs,

    // === Phase 2: Enhanced Functions ===
    // Pow,      // pow(base, exp) - Power
    // Exp,      // exp(x) - e^x
    // Log,      // log(x) - Natural log
    // Log10,    // log10(x) - Base-10 log
    //
    // Tan,      // tan(x) - Tangent
    // Atan,     // atan(x) - Arc tangent
    // Atan2,    // atan2(y, x) - Arc tangent (2-arg)
    //
    // Floor,    // floor(x) - Round down
    // Ceil,     // ceil(x) - Round up
    // Round,    // round(x) - Round to nearest
    //
    // Min,      // min(a, b) - Minimum
    // Max,      // max(a, b) - Maximum
    // Clamp,    // clamp(x, min, max) - Clamp to range
    //
    // Rand,     // rand() or rand(max) - Random number
}

impl BuiltinFunc {
    /// Parse function name from string.
    ///
    /// Returns None if the name doesn't match any built-in function.
    ///
    /// ```
    /// use milkdropper_preset::eval::builtins::BuiltinFunc;
    ///
    /// assert_eq!(BuiltinFunc::from_str("sin"), Some(BuiltinFunc::Sin));
    /// assert_eq!(BuiltinFunc::from_str("unknown"), None);
    /// ```
    pub fn from_str(name: &str) -> Option<Self> {
        match name {
            // Phase 1
            "sin" => Some(BuiltinFunc::Sin),
            "cos" => Some(BuiltinFunc::Cos),
            "sqrt" => Some(BuiltinFunc::Sqrt),
            "abs" => Some(BuiltinFunc::Abs),

            // Phase 2
            // "pow" => Some(BuiltinFunc::Pow),
            // "exp" => Some(BuiltinFunc::Exp),
            // ...

            _ => None,
        }
    }

    /// Get the number of arguments this function expects.
    ///
    /// Used by the compiler to validate function calls.
    pub fn arg_count(&self) -> usize {
        match self {
            // All Phase 1 functions take 1 argument
            BuiltinFunc::Sin | BuiltinFunc::Cos | BuiltinFunc::Sqrt | BuiltinFunc::Abs => 1,

            // Phase 2: 2-argument functions
            // BuiltinFunc::Pow | BuiltinFunc::Atan2 | BuiltinFunc::Min | BuiltinFunc::Max => 2,
            //
            // BuiltinFunc::Clamp => 3,
            //
            // BuiltinFunc::Rand => 0 or 1 (variable args, would need special handling)
        }
    }

    /// Convert function to bytecode instruction.
    ///
    /// Used by the compiler to emit the correct instruction.
    #[allow(clippy::wrong_self_convention)] // This is a conversion method
    pub fn to_instruction(&self) -> Instruction {
        match self {
            BuiltinFunc::Sin => Instruction::Sin,
            BuiltinFunc::Cos => Instruction::Cos,
            BuiltinFunc::Sqrt => Instruction::Sqrt,
            BuiltinFunc::Abs => Instruction::Abs,

            // Phase 2
            // BuiltinFunc::Pow => Instruction::Pow,
            // ...
        }
    }

    /// Execute the function with the given arguments.
    ///
    /// This is called by the VM when executing function instructions.
    /// It assumes the arguments have already been popped from the stack.
    ///
    /// Returns an error for domain errors (e.g., sqrt of negative number).
    #[allow(dead_code)] // Used in tests
    pub fn call(&self, args: &[f32]) -> Result<f32, VMError> {
        // Verify argument count
        let expected = self.arg_count();
        if args.len() != expected {
            return Err(VMError::WrongArgCount {
                expected,
                found: args.len(),
            });
        }

        // Execute function
        match self {
            BuiltinFunc::Sin => {
                // sin(x) - always safe
                Ok(args[0].sin())
            }

            BuiltinFunc::Cos => {
                // cos(x) - always safe
                Ok(args[0].cos())
            }

            BuiltinFunc::Sqrt => {
                // sqrt(x) - check for negative input
                let x = args[0];
                if x < 0.0 {
                    // Option 1: Return error
                    // Err(VMError::Math(format!("sqrt of negative number: {}", x)))

                    // Option 2: Return 0.0 (more forgiving, matches ns-eel2 behavior)
                    Ok(0.0)
                } else {
                    Ok(x.sqrt())
                }
            }

            BuiltinFunc::Abs => {
                // abs(x) - always safe
                Ok(args[0].abs())
            }

            // Phase 2 functions would go here
        }
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_from_str() {
        assert_eq!(BuiltinFunc::from_str("sin"), Some(BuiltinFunc::Sin));
        assert_eq!(BuiltinFunc::from_str("cos"), Some(BuiltinFunc::Cos));
        assert_eq!(BuiltinFunc::from_str("sqrt"), Some(BuiltinFunc::Sqrt));
        assert_eq!(BuiltinFunc::from_str("abs"), Some(BuiltinFunc::Abs));
        assert_eq!(BuiltinFunc::from_str("unknown"), None);
    }

    #[test]
    fn test_arg_count() {
        assert_eq!(BuiltinFunc::Sin.arg_count(), 1);
        assert_eq!(BuiltinFunc::Cos.arg_count(), 1);
        assert_eq!(BuiltinFunc::Sqrt.arg_count(), 1);
        assert_eq!(BuiltinFunc::Abs.arg_count(), 1);
    }

    #[test]
    fn test_to_instruction() {
        assert_eq!(BuiltinFunc::Sin.to_instruction(), Instruction::Sin);
        assert_eq!(BuiltinFunc::Cos.to_instruction(), Instruction::Cos);
        assert_eq!(BuiltinFunc::Sqrt.to_instruction(), Instruction::Sqrt);
        assert_eq!(BuiltinFunc::Abs.to_instruction(), Instruction::Abs);
    }

    #[test]
    fn test_call_sin() {
        let result = BuiltinFunc::Sin.call(&[0.0]).unwrap();
        assert!((result - 0.0).abs() < 1e-6);

        let result = BuiltinFunc::Sin.call(&[std::f32::consts::PI / 2.0]).unwrap();
        assert!((result - 1.0).abs() < 1e-6);
    }

    #[test]
    fn test_call_cos() {
        let result = BuiltinFunc::Cos.call(&[0.0]).unwrap();
        assert!((result - 1.0).abs() < 1e-6);

        let result = BuiltinFunc::Cos.call(&[std::f32::consts::PI]).unwrap();
        assert!((result - (-1.0)).abs() < 1e-6);
    }

    #[test]
    fn test_call_sqrt() {
        let result = BuiltinFunc::Sqrt.call(&[4.0]).unwrap();
        assert!((result - 2.0).abs() < 1e-6);

        let result = BuiltinFunc::Sqrt.call(&[9.0]).unwrap();
        assert!((result - 3.0).abs() < 1e-6);

        // Negative input returns 0.0 (forgiving)
        let result = BuiltinFunc::Sqrt.call(&[-1.0]).unwrap();
        assert_eq!(result, 0.0);
    }

    #[test]
    fn test_call_abs() {
        let result = BuiltinFunc::Abs.call(&[5.0]).unwrap();
        assert_eq!(result, 5.0);

        let result = BuiltinFunc::Abs.call(&[-5.0]).unwrap();
        assert_eq!(result, 5.0);

        let result = BuiltinFunc::Abs.call(&[0.0]).unwrap();
        assert_eq!(result, 0.0);
    }

    #[test]
    fn test_call_wrong_arg_count() {
        // sin expects 1 argument
        assert!(BuiltinFunc::Sin.call(&[]).is_err());
        assert!(BuiltinFunc::Sin.call(&[1.0, 2.0]).is_err());
    }
}

