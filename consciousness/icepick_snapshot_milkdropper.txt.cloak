----- FILE: ./crates/milkdropper-preset/src/eval/parser.rs -----
//! Recursive descent parser for expression language.
//!
//! The parser converts a stream of tokens into an Abstract Syntax Tree (AST).
//! It uses recursive descent with Pratt parsing for operator precedence.
//!
//! ## Grammar
//!
//! ```text
//! program     → statement*
//! statement   → assignment | expression
//! assignment  → IDENT '=' expression ';'?
//! expression  → term (('+' | '-') term)*
//! term        → factor (('*' | '/') factor)*
//! factor      → MINUS factor | primary
//! primary     → NUMBER | IDENT | funcCall | '(' expression ')'
//! funcCall    → IDENT '(' args? ')'
//! args        → expression (',' expression)*
//! ```
//!
//! ## Example
//!
//! ```
//! use milkdropper_preset::eval::{Lexer, Parser};
//!
//! let lexer = Lexer::new("q1 = bass + mid * 0.5");
//! let mut parser = Parser::new(lexer);
//! let ast = parser.parse().unwrap();
//! ```

use crate::error::PresetError;
use crate::eval::ast::{BinOpKind, Expr, UnaryOpKind, VarRef};
use crate::eval::lexer::{Lexer, Token};

/// Recursive descent parser for expression language.
pub struct Parser {
    /// Lexer (token source)
    lexer: Lexer,
    /// Current token (lookahead)
    current: Token,
}

impl Parser {
    /// Create a new parser from a lexer.
    ///
    /// ```
    /// use milkdropper_preset::eval::{Lexer, Parser};
    ///
    /// let lexer = Lexer::new("bass + mid");
    /// let parser = Parser::new(lexer);
    /// ```
    pub fn new(mut lexer: Lexer) -> Self {
        let current = lexer.next_token().unwrap_or(Token::Eof);
        Self { lexer, current }
    }

    /// Create a parser directly from a string.
    ///
    /// Convenience method that creates the lexer internally.
    ///
    /// ```
    /// use milkdropper_preset::eval::Parser;
    ///
    /// let parser = Parser::from_str("bass + mid");
    /// ```
    pub fn from_str(input: &str) -> Self {
        Self::new(Lexer::new(input))
    }

    /// Advance to the next token.
    fn advance(&mut self) -> Result<(), PresetError> {
        self.current = self
            .lexer
            .next_token()
            .map_err(|e| PresetError::Lex {
                msg: e.to_string(),
                pos: 0,
            })?;
        Ok(())
    }

    /// Check if current token matches expected token.
    fn expect(&mut self, expected: Token) -> Result<(), PresetError> {
        if self.current == expected {
            self.advance()?;
            Ok(())
        } else {
            Err(PresetError::Parse {
                expected: format!("{:?}", expected),
                found: format!("{:?}", self.current),
                pos: 0,
            })
        }
    }

    /// Parse a complete expression.
    ///
    /// This is the main entry point for parsing. It handles both:
    /// - Assignments: `q1 = bass + mid`
    /// - Expressions: `bass + mid * 0.5`
    ///
    /// Returns the parsed AST.
    pub fn parse(&mut self) -> Result<Expr, PresetError> {
        self.statement()
    }

    /// Parse a statement (assignment or expression).
    fn statement(&mut self) -> Result<Expr, PresetError> {
        // Try to parse as assignment
        // Look ahead for: IDENT '=' ...
        if let Token::Ident(name) = &self.current {
            let name = name.clone();

            // Try to parse as variable reference
            if let Some(var_ref) = VarRef::from_str(&name) {
                // Look ahead: advance past identifier and check for '='
                self.advance()?; // consume identifier

                if self.current == Token::Eq {
                    // This is an assignment!
                    if !var_ref.is_writable() {
                        return Err(PresetError::Compile(format!(
                            "Cannot assign to read-only variable: {}",
                            name
                        )));
                    }

                    self.advance()?; // consume '='

                    let value = self.expression()?;

                    // Optional semicolon
                    if self.current == Token::Semicolon {
                        self.advance()?;
                    }

                    return Ok(Expr::Assign(var_ref, Box::new(value)));
                } else {
                    // Not an assignment - we need to parse this identifier as an expression
                    // Put the identifier back as a variable expression manually
                    // This is a bit hacky but works for our needs
                    let mut expr = Expr::Variable(var_ref);

                    // Continue parsing as expression from current position
                    // Check if there are operators following
                    while matches!(self.current, Token::Plus | Token::Minus) {
                        let op = match self.current {
                            Token::Plus => BinOpKind::Add,
                            Token::Minus => BinOpKind::Sub,
                            _ => unreachable!(),
                        };
                        self.advance()?;
                        let right = self.term()?;
                        expr = Expr::BinOp(op, Box::new(expr), Box::new(right));
                    }

                    // Optional semicolon
                    if self.current == Token::Semicolon {
                        self.advance()?;
                    }

                    return Ok(expr);
                }
            }
        }

        // Not an assignment, parse as expression
        let expr = self.expression()?;

        // Optional semicolon
        if self.current == Token::Semicolon {
            self.advance()?;
        }

        Ok(expr)
    }

    /// Parse an expression (handles + and -).
    ///
    /// Grammar: expression → term (('+' | '-') term)*
    fn expression(&mut self) -> Result<Expr, PresetError> {
        let mut left = self.term()?;

        while matches!(self.current, Token::Plus | Token::Minus) {
            let op = match self.current {
                Token::Plus => BinOpKind::Add,
                Token::Minus => BinOpKind::Sub,
                _ => unreachable!(),
            };

            self.advance()?;
            let right = self.term()?;

            left = Expr::BinOp(op, Box::new(left), Box::new(right));
        }

        Ok(left)
    }

    /// Parse a term (handles * and /).
    ///
    /// Grammar: term → factor (('*' | '/') factor)*
    fn term(&mut self) -> Result<Expr, PresetError> {
        let mut left = self.factor()?;

        while matches!(self.current, Token::Star | Token::Slash) {
            let op = match self.current {
                Token::Star => BinOpKind::Mul,
                Token::Slash => BinOpKind::Div,
                _ => unreachable!(),
            };

            self.advance()?;
            let right = self.factor()?;

            left = Expr::BinOp(op, Box::new(left), Box::new(right));
        }

        Ok(left)
    }

    /// Parse a factor (handles unary minus and primary).
    ///
    /// Grammar: factor → MINUS factor | primary
    fn factor(&mut self) -> Result<Expr, PresetError> {
        // Unary minus
        if self.current == Token::Minus {
            self.advance()?;
            let operand = self.factor()?;
            return Ok(Expr::UnaryOp(UnaryOpKind::Neg, Box::new(operand)));
        }

        self.primary()
    }

    /// Parse a primary expression.
    ///
    /// Grammar: primary → NUMBER | IDENT | funcCall | '(' expression ')'
    fn primary(&mut self) -> Result<Expr, PresetError> {
        match &self.current {
            // Number literal
            Token::Number(n) => {
                let num = *n;
                self.advance()?;
                Ok(Expr::Literal(num))
            }

            // Identifier (variable or function call)
            Token::Ident(name) => {
                let name = name.clone();
                self.advance()?;

                // Check for function call: IDENT '('
                if self.current == Token::LParen {
                    // Function call
                    self.advance()?; // consume '('

                    // Parse arguments
                    let args = if self.current == Token::RParen {
                        // No arguments
                        vec![]
                    } else {
                        self.parse_args()?
                    };

                    self.expect(Token::RParen)?;

                    Ok(Expr::FuncCall(name, args))
                } else {
                    // Variable reference
                    let var_ref = VarRef::from_str(&name).ok_or_else(|| {
                        PresetError::UnknownVariable(name.clone())
                    })?;
                    Ok(Expr::Variable(var_ref))
                }
            }

            // Parenthesized expression
            Token::LParen => {
                self.advance()?; // consume '('
                let expr = self.expression()?;
                self.expect(Token::RParen)?;
                Ok(expr)
            }

            // Unexpected token
            _ => Err(PresetError::Parse {
                expected: "number, identifier, or '('".to_string(),
                found: format!("{:?}", self.current),
                pos: 0,
            }),
        }
    }

    /// Parse function arguments.
    ///
    /// Grammar: args → expression (',' expression)*
    fn parse_args(&mut self) -> Result<Vec<Expr>, PresetError> {
        let mut args = vec![self.expression()?];

        while self.current == Token::Comma {
            self.advance()?; // consume ','
            args.push(self.expression()?);
        }

        Ok(args)
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_parse_literal() {
        let mut parser = Parser::from_str("42");
        let ast = parser.parse().unwrap();
        assert!(matches!(ast, Expr::Literal(42.0)));
    }

    #[test]
    fn test_parse_variable() {
        let mut parser = Parser::from_str("bass");
        let ast = parser.parse().unwrap();
        assert!(matches!(ast, Expr::Variable(VarRef::Bass)));
    }

    #[test]
    fn test_parse_binop_add() {
        let mut parser = Parser::from_str("bass + mid");
        let ast = parser.parse().unwrap();
        // Check structure without box patterns
        if let Expr::BinOp(BinOpKind::Add, left, right) = ast {
            assert!(matches!(*left, Expr::Variable(VarRef::Bass)));
            assert!(matches!(*right, Expr::Variable(VarRef::Mid)));
        } else {
            panic!("Expected BinOp Add");
        }
    }

    #[test]
    fn test_parse_binop_precedence() {
        // bass + mid * 2 should parse as: bass + (mid * 2)
        let mut parser = Parser::from_str("bass + mid * 2");
        let ast = parser.parse().unwrap();

        // Should be: Add(bass, Mul(mid, 2))
        if let Expr::BinOp(BinOpKind::Add, left, right) = ast {
            assert!(matches!(*left, Expr::Variable(VarRef::Bass)));
            // Check right is Mul(mid, 2)
            if let Expr::BinOp(BinOpKind::Mul, mul_left, mul_right) = &*right {
                assert!(matches!(**mul_left, Expr::Variable(VarRef::Mid)));
                assert!(matches!(**mul_right, Expr::Literal(2.0)));
            } else {
                panic!("Expected Mul in right operand");
            }
        } else {
            panic!("Expected Add expression");
        }
    }

    #[test]
    fn test_parse_unary_neg() {
        let mut parser = Parser::from_str("-bass");
        let ast = parser.parse().unwrap();
        if let Expr::UnaryOp(UnaryOpKind::Neg, operand) = ast {
            assert!(matches!(*operand, Expr::Variable(VarRef::Bass)));
        } else {
            panic!("Expected UnaryOp Neg");
        }
    }

    #[test]
    fn test_parse_parentheses() {
        // (bass + mid) * 2 should parse as: Mul(Add(bass, mid), 2)
        let mut parser = Parser::from_str("(bass + mid) * 2");
        let ast = parser.parse().unwrap();

        if let Expr::BinOp(BinOpKind::Mul, left, right) = ast {
            // Check left is Add(bass, mid)
            if let Expr::BinOp(BinOpKind::Add, add_left, add_right) = &*left {
                assert!(matches!(**add_left, Expr::Variable(VarRef::Bass)));
                assert!(matches!(**add_right, Expr::Variable(VarRef::Mid)));
            } else {
                panic!("Expected Add in left operand");
            }
            assert!(matches!(*right, Expr::Literal(2.0)));
        } else {
            panic!("Expected Mul expression");
        }
    }

    #[test]
    fn test_parse_function_call() {
        let mut parser = Parser::from_str("sin(bass)");
        let ast = parser.parse().unwrap();
        assert!(matches!(
            ast,
            Expr::FuncCall(name, args) if name == "sin" && args.len() == 1
        ));
    }

    #[test]
    fn test_parse_function_call_multiple_args() {
        let mut parser = Parser::from_str("atan2(mid, bass)");
        let ast = parser.parse().unwrap();
        assert!(matches!(
            ast,
            Expr::FuncCall(name, args) if name == "atan2" && args.len() == 2
        ));
    }

    #[test]
    fn test_parse_assignment() {
        let mut parser = Parser::from_str("q1 = bass + mid");
        let ast = parser.parse().unwrap();
        if let Expr::Assign(var, expr) = ast {
            assert!(matches!(var, VarRef::Q(1)));
            assert!(matches!(*expr, Expr::BinOp(BinOpKind::Add, _, _)));
        } else {
            panic!("Expected Assign");
        }
    }

    #[test]
    fn test_parse_complex_expression() {
        // q1 = sin(bass + mid) * 0.5
        let mut parser = Parser::from_str("q1 = sin(bass + mid) * 0.5");
        let ast = parser.parse().unwrap();

        // Should be: Assign(q1, Mul(sin(Add(bass, mid)), 0.5))
        assert!(matches!(ast, Expr::Assign(VarRef::Q(1), _)));
    }

    #[test]
    fn test_parse_readonly_assignment_error() {
        // Can't assign to bass (read-only)
        let mut parser = Parser::from_str("bass = 1.0");
        assert!(parser.parse().is_err());
    }
}

