----- FILE: ./crates/milkdropper-preset/src/engine.rs -----
//! Preset engine - High-level API for preset execution.
//!
//! The PresetEngine provides a simple, ergonomic interface for loading
//! and executing presets. It manages the VM and handles all the details
//! of expression evaluation.
//!
//! ## Example
//!
//! ```no_run
//! use milkdropper_preset::{PresetEngine, PresetContext};
//!
//! // Create engine
//! let mut engine = PresetEngine::new();
//!
//! // Load preset
//! engine.load_preset("presets/example.milk")?;
//!
//! // Evaluation loop (typically 60fps)
//! loop {
//!     // Create context with audio data
//!     let mut ctx = PresetContext::new();
//!     ctx.bass = get_bass_energy(); // From audio analyzer
//!     ctx.mid = get_mid_energy();
//!     ctx.treb = get_treb_energy();
//!     ctx.time = get_elapsed_time();
//!
//!     // Execute preset expressions
//!     engine.evaluate_frame(&mut ctx)?;
//!
//!     // Use computed values for rendering
//!     render_frame(&ctx);
//! }
//! # fn get_bass_energy() -> f32 { 0.0 }
//! # fn get_mid_energy() -> f32 { 0.0 }
//! # fn get_treb_energy() -> f32 { 0.0 }
//! # fn get_elapsed_time() -> f32 { 0.0 }
//! # fn render_frame(_ctx: &PresetContext) {}
//! # Ok::<(), Box<dyn std::error::Error>>(())
//! ```

use std::path::Path;

use crate::context::PresetContext;
use crate::error::PresetError;
use crate::eval::vm::VM;
use crate::parser::parse_preset_file;
use crate::preset::Preset;

/// Preset execution engine.
///
/// This provides a high-level API for loading and executing presets.
/// It manages the VM and current preset state.
pub struct PresetEngine {
    /// Currently loaded preset (if any)
    current_preset: Option<Preset>,

    /// Virtual machine for bytecode execution
    vm: VM,
}

impl PresetEngine {
    /// Create a new preset engine.
    ///
    /// ```
    /// use milkdropper_preset::PresetEngine;
    ///
    /// let engine = PresetEngine::new();
    /// ```
    pub fn new() -> Self {
        Self {
            current_preset: None,
            vm: VM::new(),
        }
    }

    /// Create a new preset engine with custom VM settings.
    ///
    /// ```
    /// use milkdropper_preset::{PresetEngine, VM};
    ///
    /// let vm = VM::with_max_instructions(50_000);
    /// let engine = PresetEngine::with_vm(vm);
    /// ```
    pub fn with_vm(vm: VM) -> Self {
        Self {
            current_preset: None,
            vm,
        }
    }

    /// Load a preset from a file.
    ///
    /// This parses the .milk file and compiles all expressions to bytecode.
    /// The preset becomes the current preset for evaluation.
    ///
    /// ```no_run
    /// use milkdropper_preset::PresetEngine;
    ///
    /// let mut engine = PresetEngine::new();
    /// engine.load_preset("presets/example.milk")?;
    /// # Ok::<(), Box<dyn std::error::Error>>(())
    /// ```
    pub fn load_preset(&mut self, path: impl AsRef<Path>) -> Result<&Preset, PresetError> {
        let preset = parse_preset_file(path)?;
        self.current_preset = Some(preset);
        Ok(self.current_preset.as_ref().unwrap())
    }

    /// Load a preset from a string.
    ///
    /// Useful for testing or loading presets from non-file sources.
    ///
    /// ```
    /// use milkdropper_preset::PresetEngine;
    ///
    /// let content = r#"
    /// [preset00]
    /// fRating=3.0
    /// per_frame_1=q1 = bass;
    /// "#;
    ///
    /// let mut engine = PresetEngine::new();
    /// engine.load_preset_from_string(content, "Test".to_string())?;
    /// # Ok::<(), Box<dyn std::error::Error>>(())
    /// ```
    pub fn load_preset_from_string(
        &mut self,
        content: &str,
        name: String,
    ) -> Result<&Preset, PresetError> {
        let preset = crate::parser::parse_preset_content(content, name)?;
        self.current_preset = Some(preset);
        Ok(self.current_preset.as_ref().unwrap())
    }

    /// Get the currently loaded preset.
    ///
    /// Returns None if no preset is loaded.
    pub fn current_preset(&self) -> Option<&Preset> {
        self.current_preset.as_ref()
    }

    /// Check if a preset is currently loaded.
    pub fn has_preset(&self) -> bool {
        self.current_preset.is_some()
    }

    /// Evaluate the current preset for one frame.
    ///
    /// This executes all per-frame expressions with the given context.
    /// The context should be populated with audio data before calling.
    ///
    /// ## Process
    ///
    /// 1. Sync context to internal array (bass, mid, etc.)
    /// 2. Execute all per-frame expressions sequentially
    /// 3. Sync results back to context (q1-q32, zoom, etc.)
    ///
    /// ## Example
    ///
    /// ```no_run
    /// use milkdropper_preset::{PresetEngine, PresetContext};
    ///
    /// let mut engine = PresetEngine::new();
    /// engine.load_preset("presets/example.milk")?;
    ///
    /// let mut ctx = PresetContext::new();
    /// ctx.bass = 0.8;
    /// ctx.mid = 0.5;
    /// ctx.time = 1.5;
    ///
    /// engine.evaluate_frame(&mut ctx)?;
    ///
    /// // ctx.q[0], ctx.zoom, etc. now contain computed values
    /// # Ok::<(), Box<dyn std::error::Error>>(())
    /// ```
    pub fn evaluate_frame(&mut self, context: &mut PresetContext) -> Result<(), PresetError> {
        let preset = self
            .current_preset
            .as_ref()
            .ok_or_else(|| PresetError::Compile("No preset loaded".to_string()))?;

        // Sync context to internal array
        context.sync_to_array();

        // Execute all per-frame expressions
        for program in &preset.per_frame {
            self.vm.execute(program, context)?;
        }

        // Sync results back to named fields
        context.sync_from_array();

        Ok(())
    }

    /// Clear the VM stack.
    ///
    /// This is typically not needed (the VM clears automatically), but
    /// can be useful for debugging or resetting state.
    pub fn clear_vm(&mut self) {
        self.vm.clear();
    }

    /// Get the number of per-frame expressions in the current preset.
    ///
    /// Returns 0 if no preset is loaded.
    pub fn expression_count(&self) -> usize {
        self.current_preset
            .as_ref()
            .map(|p| p.per_frame_count())
            .unwrap_or(0)
    }
}

impl Default for PresetEngine {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_engine_creation() {
        let engine = PresetEngine::new();
        assert!(!engine.has_preset());
        assert_eq!(engine.expression_count(), 0);
    }

    #[test]
    fn test_load_preset_from_string() {
        let content = r#"
[preset00]
fRating=4.0
zoom=1.0
per_frame_1=q1 = bass;
per_frame_2=zoom = zoom + q1 * 0.1;
"#;

        let mut engine = PresetEngine::new();
        let preset = engine
            .load_preset_from_string(content, "Test".to_string())
            .unwrap();

        assert_eq!(preset.name, "Test");
        assert_eq!(preset.rating, 4.0);
        assert!(engine.has_preset());
        assert_eq!(engine.expression_count(), 2);
    }

    #[test]
    fn test_evaluate_frame_simple() {
        let content = r#"
[preset00]
per_frame_1=q1 = bass + mid;
"#;

        let mut engine = PresetEngine::new();
        engine
            .load_preset_from_string(content, "Test".to_string())
            .unwrap();

        let mut ctx = PresetContext::new();
        ctx.bass = 0.7;
        ctx.mid = 0.3;

        engine.evaluate_frame(&mut ctx).unwrap();

        // q1 should be 0.7 + 0.3 = 1.0
        assert!((ctx.q[0] - 1.0).abs() < 1e-6);
    }

    #[test]
    fn test_evaluate_frame_complex() {
        let content = r#"
[preset00]
per_frame_1=q1 = bass + bass_att * 0.5;
per_frame_2=q2 = mid * 2.0;
per_frame_3=zoom = 1.0 + q1 * 0.1;
"#;

        let mut engine = PresetEngine::new();
        engine
            .load_preset_from_string(content, "Test".to_string())
            .unwrap();

        let mut ctx = PresetContext::new();
        ctx.bass = 0.8;
        ctx.bass_att = 0.6;
        ctx.mid = 0.5;
        ctx.zoom = 1.0;

        engine.evaluate_frame(&mut ctx).unwrap();

        // q1 = 0.8 + 0.6 * 0.5 = 1.1
        assert!((ctx.q[0] - 1.1).abs() < 1e-6);

        // q2 = 0.5 * 2.0 = 1.0
        assert!((ctx.q[1] - 1.0).abs() < 1e-6);

        // zoom = 1.0 + 1.1 * 0.1 = 1.11
        assert!((ctx.zoom - 1.11).abs() < 1e-6);
    }

    #[test]
    fn test_evaluate_frame_with_functions() {
        let content = r#"
[preset00]
per_frame_1=q1 = sin(time);
per_frame_2=q2 = abs(-bass);
"#;

        let mut engine = PresetEngine::new();
        engine
            .load_preset_from_string(content, "Test".to_string())
            .unwrap();

        let mut ctx = PresetContext::new();
        ctx.time = 0.0;
        ctx.bass = 0.5;

        engine.evaluate_frame(&mut ctx).unwrap();

        // q1 = sin(0) = 0
        assert!((ctx.q[0] - 0.0).abs() < 1e-6);

        // q2 = abs(-0.5) = 0.5
        assert!((ctx.q[1] - 0.5).abs() < 1e-6);
    }

    #[test]
    fn test_evaluate_frame_no_preset() {
        let mut engine = PresetEngine::new();
        let mut ctx = PresetContext::new();

        // Should error when no preset is loaded
        assert!(engine.evaluate_frame(&mut ctx).is_err());
    }

    #[test]
    fn test_multiple_frames() {
        let content = r#"
[preset00]
per_frame_1=q1 = q1 + bass * 0.01;
"#;

        let mut engine = PresetEngine::new();
        engine
            .load_preset_from_string(content, "Test".to_string())
            .unwrap();

        let mut ctx = PresetContext::new();
        ctx.bass = 1.0;
        ctx.q[0] = 0.0;

        // Frame 1
        engine.evaluate_frame(&mut ctx).unwrap();
        assert!((ctx.q[0] - 0.01).abs() < 1e-6);

        // Frame 2 (q1 accumulates)
        engine.evaluate_frame(&mut ctx).unwrap();
        assert!((ctx.q[0] - 0.02).abs() < 1e-6);

        // Frame 3
        engine.evaluate_frame(&mut ctx).unwrap();
        assert!((ctx.q[0] - 0.03).abs() < 1e-6);
    }
}

