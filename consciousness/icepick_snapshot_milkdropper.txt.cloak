----- FILE: ./crates/milkdropper-preset/src/eval/lexer.rs -----
//! Lexer (tokenizer) for expression language.
//!
//! The lexer converts a string of characters into a stream of tokens.
//! It's a simple state machine that scans character-by-character.
//!
//! ## Example
//!
//! ```
//! use milkdropper_preset::eval::lexer::{Lexer, Token};
//!
//! let mut lexer = Lexer::new("q1 = bass + 0.5");
//! let tokens: Vec<Token> = lexer.collect();
//!
//! // Tokens: [Ident("q1"), Eq, Ident("bass"), Plus, Number(0.5), Eof]
//! ```

use crate::error::LexError;

/// Token types recognized by the lexer.
#[derive(Debug, Clone, PartialEq)]
pub enum Token {
    // === Literals ===
    /// Number literal (integer or float)
    Number(f32),

    // === Identifiers & Variables ===
    /// Identifier (variable name or function name)
    Ident(String),

    // === Operators ===
    /// Addition (+)
    Plus,
    /// Subtraction/Negation (-)
    Minus,
    /// Multiplication (*)
    Star,
    /// Division (/)
    Slash,

    // === Assignment ===
    /// Assignment (=)
    Eq,

    // === Grouping & Delimiters ===
    /// Left parenthesis (
    LParen,
    /// Right parenthesis )
    RParen,
    /// Comma (for function arguments)
    Comma,
    /// Semicolon (statement terminator)
    Semicolon,

    // === End of Input ===
    /// End of file/input
    Eof,
}

/// Lexer (tokenizer) for expression language.
///
/// The lexer is an iterator that produces tokens one at a time.
/// It maintains an internal position and handles whitespace automatically.
#[derive(Clone)]
pub struct Lexer {
    /// Input string
    input: Vec<char>,
    /// Current position in input
    pos: usize,
}

impl Lexer {
    /// Create a new lexer from input string.
    ///
    /// ```
    /// use milkdropper_preset::eval::lexer::Lexer;
    ///
    /// let lexer = Lexer::new("bass + mid");
    /// ```
    pub fn new(input: &str) -> Self {
        Self {
            input: input.chars().collect(),
            pos: 0,
        }
    }

    /// Peek at the current character without consuming it.
    ///
    /// Returns None if at end of input.
    fn peek(&self) -> Option<char> {
        self.input.get(self.pos).copied()
    }

    /// Advance to next character and return current one.
    ///
    /// Returns None if at end of input.
    fn advance(&mut self) -> Option<char> {
        let ch = self.peek()?;
        self.pos += 1;
        Some(ch)
    }

    /// Skip whitespace characters.
    fn skip_whitespace(&mut self) {
        while let Some(ch) = self.peek() {
            if ch.is_whitespace() {
                self.advance();
            } else {
                break;
            }
        }
    }

    /// Scan a number literal (integer or float).
    ///
    /// Handles:
    /// - Integers: 42, 123
    /// - Floats: 3.14, 0.5
    /// - Negative numbers are handled by unary minus in parser
    fn scan_number(&mut self) -> Result<Token, LexError> {
        let mut num_str = String::new();

        // Collect digits and optional decimal point
        while let Some(ch) = self.peek() {
            if ch.is_ascii_digit() || ch == '.' {
                num_str.push(ch);
                self.advance();
            } else {
                break;
            }
        }

        // Parse as f32
        num_str
            .parse::<f32>()
            .map(Token::Number)
            .map_err(|_| LexError::InvalidNumber(num_str))
    }

    /// Scan an identifier (variable name or function name).
    ///
    /// Identifiers start with a letter or underscore and can contain
    /// letters, digits, and underscores.
    ///
    /// Examples: bass, q1, wave_r, sin
    fn scan_identifier(&mut self) -> Token {
        let mut ident = String::new();

        // First character: letter or underscore
        if let Some(ch) = self.peek() {
            if ch.is_alphabetic() || ch == '_' {
                ident.push(ch);
                self.advance();
            }
        }

        // Subsequent characters: letter, digit, or underscore
        while let Some(ch) = self.peek() {
            if ch.is_alphanumeric() || ch == '_' {
                ident.push(ch);
                self.advance();
            } else {
                break;
            }
        }

        Token::Ident(ident)
    }

    /// Get the next token from the input.
    ///
    /// Returns Eof when there are no more tokens.
    /// Returns an error for unknown characters.
    pub fn next_token(&mut self) -> Result<Token, LexError> {
        // Skip whitespace
        self.skip_whitespace();

        // Check for end of input
        let ch = match self.peek() {
            Some(c) => c,
            None => return Ok(Token::Eof),
        };

        // Match character and produce token
        match ch {
            // Operators
            '+' => {
                self.advance();
                Ok(Token::Plus)
            }
            '-' => {
                self.advance();
                Ok(Token::Minus)
            }
            '*' => {
                self.advance();
                Ok(Token::Star)
            }
            '/' => {
                self.advance();
                Ok(Token::Slash)
            }

            // Assignment
            '=' => {
                self.advance();
                Ok(Token::Eq)
            }

            // Grouping
            '(' => {
                self.advance();
                Ok(Token::LParen)
            }
            ')' => {
                self.advance();
                Ok(Token::RParen)
            }

            // Delimiters
            ',' => {
                self.advance();
                Ok(Token::Comma)
            }
            ';' => {
                self.advance();
                Ok(Token::Semicolon)
            }

            // Numbers
            '0'..='9' | '.' => self.scan_number(),

            // Identifiers (variables, functions)
            'a'..='z' | 'A'..='Z' | '_' => Ok(self.scan_identifier()),

            // Unknown character
            _ => Err(LexError::UnknownChar(ch, self.pos)),
        }
    }
}

/// Implement Iterator for Lexer.
///
/// This allows using the lexer in for loops:
/// ```
/// use milkdropper_preset::eval::lexer::Lexer;
///
/// let lexer = Lexer::new("bass + mid");
/// for token in lexer {
///     println!("{:?}", token);
/// }
/// ```
///
/// Note: Errors are swallowed and iteration stops. For error handling,
/// use next_token() directly.
impl Iterator for Lexer {
    type Item = Token;

    fn next(&mut self) -> Option<Self::Item> {
        match self.next_token() {
            Ok(Token::Eof) => None,
            Ok(token) => Some(token),
            Err(_) => None, // Swallow errors, stop iteration
        }
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_single_tokens() {
        let mut lex = Lexer::new("+ - * / = ( ) , ;");
        assert_eq!(lex.next_token().unwrap(), Token::Plus);
        assert_eq!(lex.next_token().unwrap(), Token::Minus);
        assert_eq!(lex.next_token().unwrap(), Token::Star);
        assert_eq!(lex.next_token().unwrap(), Token::Slash);
        assert_eq!(lex.next_token().unwrap(), Token::Eq);
        assert_eq!(lex.next_token().unwrap(), Token::LParen);
        assert_eq!(lex.next_token().unwrap(), Token::RParen);
        assert_eq!(lex.next_token().unwrap(), Token::Comma);
        assert_eq!(lex.next_token().unwrap(), Token::Semicolon);
        assert_eq!(lex.next_token().unwrap(), Token::Eof);
    }

    #[test]
    fn test_numbers() {
        let mut lex = Lexer::new("42 3.14 0.5 0 123.456");
        assert_eq!(lex.next_token().unwrap(), Token::Number(42.0));
        assert_eq!(lex.next_token().unwrap(), Token::Number(3.14));
        assert_eq!(lex.next_token().unwrap(), Token::Number(0.5));
        assert_eq!(lex.next_token().unwrap(), Token::Number(0.0));
        assert_eq!(lex.next_token().unwrap(), Token::Number(123.456));
    }

    #[test]
    fn test_identifiers() {
        let mut lex = Lexer::new("bass mid q1 wave_r sin");
        assert_eq!(lex.next_token().unwrap(), Token::Ident("bass".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Ident("mid".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Ident("q1".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Ident("wave_r".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Ident("sin".to_string()));
    }

    #[test]
    fn test_expression() {
        let mut lex = Lexer::new("q1 = bass + mid * 0.5");
        assert_eq!(lex.next_token().unwrap(), Token::Ident("q1".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Eq);
        assert_eq!(lex.next_token().unwrap(), Token::Ident("bass".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Plus);
        assert_eq!(lex.next_token().unwrap(), Token::Ident("mid".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Star);
        assert_eq!(lex.next_token().unwrap(), Token::Number(0.5));
        assert_eq!(lex.next_token().unwrap(), Token::Eof);
    }

    #[test]
    fn test_function_call() {
        let mut lex = Lexer::new("sin(bass + mid)");
        assert_eq!(lex.next_token().unwrap(), Token::Ident("sin".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::LParen);
        assert_eq!(lex.next_token().unwrap(), Token::Ident("bass".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Plus);
        assert_eq!(lex.next_token().unwrap(), Token::Ident("mid".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::RParen);
        assert_eq!(lex.next_token().unwrap(), Token::Eof);
    }

    #[test]
    fn test_whitespace() {
        let mut lex = Lexer::new("  bass   +   mid  ");
        assert_eq!(lex.next_token().unwrap(), Token::Ident("bass".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Plus);
        assert_eq!(lex.next_token().unwrap(), Token::Ident("mid".to_string()));
        assert_eq!(lex.next_token().unwrap(), Token::Eof);
    }

    #[test]
    fn test_unknown_char() {
        let mut lex = Lexer::new("bass @ mid");
        assert_eq!(lex.next_token().unwrap(), Token::Ident("bass".to_string()));
        assert!(matches!(lex.next_token(), Err(LexError::UnknownChar('@', _))));
    }

    #[test]
    fn test_iterator() {
        let lex = Lexer::new("bass + mid");
        let tokens: Vec<Token> = lex.collect();
        assert_eq!(tokens.len(), 3);
        assert!(matches!(tokens[0], Token::Ident(_)));
        assert_eq!(tokens[1], Token::Plus);
        assert!(matches!(tokens[2], Token::Ident(_)));
    }
}

