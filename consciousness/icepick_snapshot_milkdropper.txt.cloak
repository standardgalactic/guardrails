//! Error types for preset loading and expression evaluation.
//!
//! This module defines all the errors that can occur during:
//! - Lexing (tokenization)
//! - Parsing (AST building)
//! - Compilation (bytecode generation)
//! - Execution (VM runtime)
//! - Preset file loading

use std::fmt;
use thiserror::Error;

use crate::context::VarIndex;

/// Main error type for preset operations.
///
/// This encompasses all errors from lexing through execution.
#[derive(Debug, Error)]
pub enum PresetError {
    /// Lexer error during tokenization
    #[error("Lexer error at position {pos}: {msg}")]
    Lex { msg: String, pos: usize },

    /// Parser error during AST construction
    #[error("Parse error at position {pos}: expected {expected}, found {found}")]
    Parse {
        expected: String,
        found: String,
        pos: usize,
    },

    /// Compilation error during bytecode generation
    #[error("Compilation error: {0}")]
    Compile(String),

    /// VM runtime error
    #[error("VM error: {0}")]
    VM(#[from] VMError),

    /// I/O error (file loading)
    #[error("I/O error: {0}")]
    Io(#[from] std::io::Error),

    /// Preset file format error
    #[error("Preset format error: {0}")]
    Format(String),

    /// Unknown function name
    #[error("Unknown function: {0}")]
    UnknownFunction(String),

    /// Unknown variable name
    #[error("Unknown variable: {0}")]
    UnknownVariable(String),

    /// Invalid number literal
    #[error("Invalid number literal: {0}")]
    InvalidNumber(String),
}

/// Virtual machine runtime errors.
///
/// These occur during bytecode execution and are designed to be
/// non-fatal (we can continue rendering even if one frame fails).
#[derive(Debug, Error, Clone)]
pub enum VMError {
    /// Stack underflow (tried to pop empty stack)
    #[error("Stack underflow - attempted to pop from empty stack")]
    StackUnderflow,

    /// Stack overflow (exceeded maximum depth)
    #[error("Stack overflow - exceeded maximum stack depth of {0}")]
    StackOverflow(usize),

    /// Instruction limit exceeded (possible infinite loop)
    #[error("Instruction limit exceeded ({0} instructions) - possible infinite loop")]
    InstructionLimitExceeded(usize),

    /// Invalid variable index (out of bounds)
    #[error("Invalid variable index: {0:?}")]
    InvalidVariableIndex(VarIndex),

    /// Wrong number of function arguments
    #[error("Wrong argument count for function: expected {expected}, found {found}")]
    WrongArgCount { expected: usize, found: usize },

    /// Math error (domain error, etc.)
    #[error("Math error: {0}")]
    Math(String),

    /// Division by zero
    #[error("Division by zero")]
    DivisionByZero,

    /// Invalid bytecode instruction
    #[error("Invalid bytecode instruction at offset {0}")]
    InvalidInstruction(usize),
}

/// Lexer-specific errors.
///
/// These are internal and get wrapped in PresetError::Lex.
#[derive(Debug, Clone)]
pub(crate) enum LexError {
    /// Unknown character encountered
    UnknownChar(char, usize),

    /// Invalid number format
    InvalidNumber(String),

    /// Unexpected end of input (Phase 2)
    #[allow(dead_code)]
    UnexpectedEof,
}

impl fmt::Display for LexError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            LexError::UnknownChar(c, pos) => {
                write!(f, "Unknown character '{}' at position {}", c, pos)
            }
            LexError::InvalidNumber(s) => {
                write!(f, "Invalid number format: {}", s)
            }
            LexError::UnexpectedEof => {
                write!(f, "Unexpected end of input")
            }
        }
    }
}

/// Parser-specific errors.
///
/// These are internal and get wrapped in PresetError::Parse.
#[derive(Debug, Clone)]
#[allow(dead_code)] // Phase 2
pub(crate) enum ParseError {
    /// Unexpected token
    UnexpectedToken {
        expected: String,
        found: String,
        pos: usize,
    },

    /// Unmatched parenthesis
    UnmatchedParen(usize),

    /// Unexpected end of input
    UnexpectedEof,

    /// Invalid assignment target
    InvalidAssignmentTarget(String),
}

impl fmt::Display for ParseError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            ParseError::UnexpectedToken {
                expected,
                found,
                pos,
            } => {
                write!(
                    f,
                    "Unexpected token at position {}: expected {}, found {}",
                    pos, expected, found
                )
            }
            ParseError::UnmatchedParen(pos) => {
                write!(f, "Unmatched parenthesis at position {}", pos)
            }
            ParseError::UnexpectedEof => {
                write!(f, "Unexpected end of input")
            }
            ParseError::InvalidAssignmentTarget(target) => {
                write!(f, "Invalid assignment target: {}", target)
            }
        }
    }
}

----- END FILE: ./crates/milkdropper-preset/src/error.rs -----


----- FILE: ./crates/milkdropper-preset/src/eval/ast.rs -----
//! Abstract Syntax Tree (AST) for expression language.
//!
//! The AST represents the structure of parsed expressions before
//! they are compiled to bytecode. It's a tree of expression nodes.
//!
//! ## Example
//!
//! The expression `q1 = bass + mid * 0.5` becomes:
//!
//! ```text
//! Assign(
//!     Q(1),
//!     BinOp(
//!         Add,
//!         Variable(Bass),
//!         BinOp(
//!             Mul,
//!             Variable(Mid),
//!             Literal(0.5)
//!         )
//!     )
//! )
//! ```

use crate::context::VarIndex;

/// Expression AST node.
///
/// This is the core of our expression language. Each variant represents
/// a different kind of expression that can appear in presets.
#[derive(Debug, Clone, PartialEq)]
pub enum Expr {
    /// Literal number: 3.14, 42, 0.5
    Literal(f32),

    /// Variable reference: bass, q1, zoom, etc.
    Variable(VarRef),

    /// Binary operation: a + b, x * y, etc.
    BinOp(BinOpKind, Box<Expr>, Box<Expr>),

    /// Unary operation: -x, !x (Phase 2)
    UnaryOp(UnaryOpKind, Box<Expr>),

    /// Function call: sin(x), atan2(y, x), etc.
    FuncCall(String, Vec<Expr>),

    /// Assignment: q1 = expr
    Assign(VarRef, Box<Expr>),
}

/// Binary operator kind.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum BinOpKind {
    /// Addition (+)
    Add,
    /// Subtraction (-)
    Sub,
    /// Multiplication (*)
    Mul,
    /// Division (/)
    Div,

    // Phase 2: Comparison and logic
    // Gt,      // >
    // Lt,      // <
    // Eq,      // ==
    // Ne,      // !=
    // And,     // &&
    // Or,      // ||
}

/// Unary operator kind.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum UnaryOpKind {
    /// Negation (-)
    Neg,

    // Phase 2: Logical not
    // Not,     // !
}

/// Variable reference.
///
/// This enum represents all variables that can be accessed in expressions.
/// Each variant maps to a specific VarIndex in the PresetContext.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum VarRef {
    // === Audio Input Variables (Read-Only) ===
    /// Bass frequency energy
    Bass,
    /// Mid frequency energy
    Mid,
    /// Treble frequency energy
    Treb,
    /// Bass attenuated (smoothed)
    BassAtt,
    /// Mid attenuated (smoothed)
    MidAtt,
    /// Treble attenuated (smoothed)
    TrebAtt,

    // === User Variables (Read/Write) ===
    /// User variable q1-q32 (general purpose)
    Q(u8), // 1-32
    /// User variable t1-t8 (temporary)
    T(u8), // 1-8

    // === Built-in Variables (Read-Only) ===
    /// Elapsed time in seconds
    Time,
    /// Frame counter
    Frame,
    /// Frames per second
    Fps,

    // === Preset Parameters (Read/Write) ===
    /// Zoom amount
    Zoom,
    /// Rotation angle
    Rot,
    /// Center X
    Cx,
    /// Center Y
    Cy,
    /// Delta X
    Dx,
    /// Delta Y
    Dy,
    /// Warp amount
    Warp,
    /// Stretch X
    Sx,
    /// Stretch Y
    Sy,

    // === Wave Parameters ===
    /// Wave red color
    WaveR,
    /// Wave green color
    WaveG,
    /// Wave blue color
    WaveB,
    /// Wave X position
    WaveX,
    /// Wave Y position
    WaveY,
}

impl VarRef {
    /// Convert variable reference to variable index.
    ///
    /// This mapping is used by the compiler to generate LoadVar/StoreVar
    /// instructions with the correct index.
    #[allow(clippy::wrong_self_convention)] // This is a conversion method
    pub fn to_index(&self) -> VarIndex {
        use crate::context::*;

        match self {
            // Audio inputs
            VarRef::Bass => BASS_INDEX,
            VarRef::Mid => MID_INDEX,
            VarRef::Treb => TREB_INDEX,
            VarRef::BassAtt => BASS_ATT_INDEX,
            VarRef::MidAtt => MID_ATT_INDEX,
            VarRef::TrebAtt => TREB_ATT_INDEX,

            // User variables
            VarRef::Q(n) => VarIndex(5 + *n as u16), // q1 = index 6
            VarRef::T(n) => VarIndex(37 + *n as u16), // t1 = index 38

            // Built-ins
            VarRef::Time => TIME_INDEX,
            VarRef::Frame => FRAME_INDEX,
            VarRef::Fps => FPS_INDEX,

            // Preset parameters
            VarRef::Zoom => ZOOM_INDEX,
            VarRef::Rot => ROT_INDEX,
            VarRef::Cx => CX_INDEX,
            VarRef::Cy => CY_INDEX,
            VarRef::Dx => DX_INDEX,
            VarRef::Dy => DY_INDEX,
            VarRef::Warp => WARP_INDEX,
            VarRef::Sx => SX_INDEX,
            VarRef::Sy => SY_INDEX,

            // Wave parameters
            VarRef::WaveR => WAVE_R_INDEX,
            VarRef::WaveG => WAVE_G_INDEX,
            VarRef::WaveB => WAVE_B_INDEX,
            VarRef::WaveX => WAVE_X_INDEX,
            VarRef::WaveY => WAVE_Y_INDEX,
        }
    }

    /// Parse variable name from string.
    ///
    /// Returns None if the name doesn't match any known variable.
    ///
    /// Examples:
    /// - "bass" → Some(Bass)
    /// - "q1" → Some(Q(1))
    /// - "wave_r" → Some(WaveR)
    /// - "unknown" → None
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            // Audio inputs
            "bass" => Some(VarRef::Bass),
            "mid" => Some(VarRef::Mid),
            "treb" => Some(VarRef::Treb),
            "bass_att" => Some(VarRef::BassAtt),
            "mid_att" => Some(VarRef::MidAtt),
            "treb_att" => Some(VarRef::TrebAtt),

            // Built-ins
            "time" => Some(VarRef::Time),
            "frame" => Some(VarRef::Frame),
            "fps" => Some(VarRef::Fps),

            // Preset parameters
            "zoom" => Some(VarRef::Zoom),
            "rot" => Some(VarRef::Rot),
            "cx" => Some(VarRef::Cx),
            "cy" => Some(VarRef::Cy),
            "dx" => Some(VarRef::Dx),
            "dy" => Some(VarRef::Dy),
            "warp" => Some(VarRef::Warp),
            "sx" => Some(VarRef::Sx),
            "sy" => Some(VarRef::Sy),

            // Wave parameters
            "wave_r" => Some(VarRef::WaveR),
            "wave_g" => Some(VarRef::WaveG),
            "wave_b" => Some(VarRef::WaveB),
            "wave_x" => Some(VarRef::WaveX),
            "wave_y" => Some(VarRef::WaveY),

            // User variables (q1-q32, t1-t8)
            s if s.starts_with('q') => {
                // Parse "q1", "q2", ... "q32"
                let num_str = &s[1..];
                let num = num_str.parse::<u8>().ok()?;
                if (1..=32).contains(&num) {
                    Some(VarRef::Q(num))
                } else {
                    None
                }
            }
            s if s.starts_with('t') => {
                // Parse "t1", "t2", ... "t8"
                let num_str = &s[1..];
                let num = num_str.parse::<u8>().ok()?;
                if (1..=8).contains(&num) {
                    Some(VarRef::T(num))
                } else {
                    None
                }
            }

            // Unknown variable
            _ => None,
        }
    }

    /// Check if this variable is writable (can be assigned to).
    ///
    /// Audio input and built-in variables are read-only.
    /// User variables and preset parameters are writable.
    pub fn is_writable(&self) -> bool {
        matches!(
            self,
            VarRef::Q(_)
                | VarRef::T(_)
                | VarRef::Zoom
                | VarRef::Rot
                | VarRef::Cx
                | VarRef::Cy
                | VarRef::Dx
                | VarRef::Dy
                | VarRef::Warp
                | VarRef::Sx
                | VarRef::Sy
                | VarRef::WaveR
                | VarRef::WaveG
                | VarRef::WaveB
                | VarRef::WaveX
                | VarRef::WaveY
        )
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_var_ref_from_str() {
        assert_eq!(VarRef::from_str("bass"), Some(VarRef::Bass));
        assert_eq!(VarRef::from_str("mid"), Some(VarRef::Mid));
        assert_eq!(VarRef::from_str("q1"), Some(VarRef::Q(1)));
        assert_eq!(VarRef::from_str("q32"), Some(VarRef::Q(32)));
        assert_eq!(VarRef::from_str("t1"), Some(VarRef::T(1)));
        assert_eq!(VarRef::from_str("t8"), Some(VarRef::T(8)));
        assert_eq!(VarRef::from_str("zoom"), Some(VarRef::Zoom));
        assert_eq!(VarRef::from_str("wave_r"), Some(VarRef::WaveR));

        // Out of range
        assert_eq!(VarRef::from_str("q0"), None);
        assert_eq!(VarRef::from_str("q33"), None);
        assert_eq!(VarRef::from_str("t0"), None);
        assert_eq!(VarRef::from_str("t9"), None);

        // Unknown
        assert_eq!(VarRef::from_str("unknown"), None);
    }

    #[test]
    fn test_var_ref_to_index() {
        use crate::context::*;

        assert_eq!(VarRef::Bass.to_index(), BASS_INDEX);
        assert_eq!(VarRef::Q(1).to_index(), Q1_INDEX);
        assert_eq!(VarRef::Time.to_index(), TIME_INDEX);
        assert_eq!(VarRef::Zoom.to_index(), ZOOM_INDEX);
    }

    #[test]
    fn test_var_ref_is_writable() {
        // Read-only
        assert!(!VarRef::Bass.is_writable());
        assert!(!VarRef::Time.is_writable());
        assert!(!VarRef::Frame.is_writable());

        // Writable
        assert!(VarRef::Q(1).is_writable());
        assert!(VarRef::T(1).is_writable());
        assert!(VarRef::Zoom.is_writable());
        assert!(VarRef::WaveR.is_writable());
    }
}

