# Milkdropper - Audio Visualization Library
# Pure Rust reimplementation of Milkdrop2 with Phoenix Marine algorithm

[workspace]
resolver = "2"
members = [
    "crates/milkdropper",
    "crates/milkdropper-audio",
    "crates/milkdropper-preset",
    "crates/milkdropper-render",
    "crates/milkdropper-cli",
]

# Shared workspace dependencies (all crates can use these)
[workspace.dependencies]
# Logging
log = "0.4"

# Error handling
thiserror = "1.0"
anyhow = "1.0"

# Math
glam = "0.25"

# Serialization (optional)
serde = { version = "1.0", features = ["derive"] }
toml = "0.8"

# Parsing
nom = "7.1"

# Utilities
ahash = "0.8"

# GPU rendering
wgpu = "0.18"
bytemuck = { version = "1.14", features = ["derive"] }

# Software rendering
tiny-skia = "0.11"

# SIMD (optional)
simdeez = "2.0"

# no_std math (optional)
micromath = "2.1"

# Shader translation (optional)
naga = { version = "0.14", features = ["wgsl-in", "wgsl-out", "hlsl-in"] }

# Testing
criterion = "0.5"
proptest = "1.4"
approx = "0.5"

# CLI dependencies
clap = { version = "4.4", features = ["derive"] }
env_logger = "0.11"
cpal = "0.15"
winit = "0.29"
pixels = "0.13"
tokio = { version = "1.35", features = ["rt-multi-thread"] }
hound = "3.5"
symphonia = { version = "0.5", features = ["mp3", "flac", "wav"] }

# Workspace-wide settings
[workspace.package]
version = "0.1.0"
edition = "2021"
rust-version = "1.75"  # Minimum Rust version
license = "MIT OR Apache-2.0"
authors = ["Milkdropper Contributors"]
repository = "https://github.com/yourusername/milkdropper"
homepage = "https://github.com/yourusername/milkdropper"
categories = ["multimedia", "visualization", "audio"]
keywords = ["visualization", "audio", "milkdrop", "music", "vj"]

# Workspace-wide profile settings
[profile.dev]
opt-level = 1  # Basic optimizations for dev (audio needs some optimization)

[profile.release]
opt-level = 3       # Maximum speed
lto = "thin"        # Link-time optimization (thin for faster builds)
codegen-units = 16  # Parallel codegen (balance speed vs optimization)
strip = false       # Keep symbols for profiling (users can strip manually)

[profile.release-small]
inherits = "release"
opt-level = "z"     # Optimize for size
lto = true          # Full LTO for size
codegen-units = 1   # Maximum optimization
strip = true        # Strip symbols
panic = "abort"     # Smaller binary

[profile.bench]
inherits = "release"
debug = true        # Keep debug info for profilers

# Metadata
[workspace.metadata.docs.rs]
all-features = true
rustdoc-args = ["--cfg", "docsrs"]

