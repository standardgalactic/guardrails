//! Stack-based Virtual Machine for bytecode execution.
//!
//! The VM executes compiled bytecode programs in a safe, sandboxed environment.
//! It uses a stack-based architecture (like the JVM or WASM) for simplicity
//! and performance.
//!
//! ## Safety Guarantees
//!
//! - **No infinite loops**: Instruction count limit
//! - **No stack overflow**: Pre-allocated stack with bounds checking
//! - **No stack underflow**: Explicit checks before pop
//! - **No division by zero**: Returns 0.0 on division by zero
//! - **No NaN propagation**: Checks for invalid math operations
//!
//! ## Example
//!
//! ```
//! use milkdropper_preset::{PresetContext, VM};
//! use milkdropper_preset::eval::{Parser, Compiler};
//!
//! // Parse and compile expression
//! let mut parser = Parser::from_str("q1 = bass + mid * 0.5");
//! let ast = parser.parse().unwrap();
//! let compiler = Compiler::new();
//! let program = compiler.compile(&ast).unwrap();
//!
//! // Create context and inject audio data
//! let mut ctx = PresetContext::new();
//! ctx.bass = 0.8;
//! ctx.mid = 0.6;
//! ctx.sync_to_array();
//!
//! // Execute bytecode
//! let mut vm = VM::new();
//! vm.execute(&program, &mut ctx).unwrap();
//! ctx.sync_from_array();
//!
//! // q1 now contains: 0.8 + 0.6 * 0.5 = 1.1
//! assert!((ctx.q[0] - 1.1).abs() < 1e-6);
//! ```

use crate::context::PresetContext;
use crate::error::VMError;
use crate::eval::bytecode::{Instruction, Program};

/// Virtual Machine for bytecode execution.
///
/// The VM is reusable and maintains a stack for expression evaluation.
/// It can execute multiple programs sequentially.
pub struct VM {
    /// Execution stack (pre-allocated for performance)
    stack: Vec<f32>,

    /// Maximum instruction count per execution (safety limit)
    max_instructions: usize,
}

impl VM {
    /// Default maximum instruction count (10,000 instructions per frame).
    ///
    /// This prevents infinite loops while allowing complex presets.
    /// At 60fps, this is 600,000 instructions/second, which is plenty
    /// for typical preset expressions.
    pub const DEFAULT_MAX_INSTRUCTIONS: usize = 10_000;

    /// Create a new VM with default settings.
    ///
    /// ```
    /// use milkdropper_preset::VM;
    ///
    /// let vm = VM::new();
    /// ```
    pub fn new() -> Self {
        Self {
            stack: Vec::with_capacity(64), // Reasonable default stack size
            max_instructions: Self::DEFAULT_MAX_INSTRUCTIONS,
        }
    }

    /// Create a new VM with custom instruction limit.
    ///
    /// ```
    /// use milkdropper_preset::VM;
    ///
    /// let vm = VM::with_max_instructions(50_000); // Allow more complex expressions
    /// ```
    pub fn with_max_instructions(max_instructions: usize) -> Self {
        Self {
            stack: Vec::with_capacity(64),
            max_instructions,
        }
    }

    /// Execute a bytecode program.
    ///
    /// This is the main execution entry point. It:
    /// 1. Clears the stack
    /// 2. Reserves stack space based on program's max depth
    /// 3. Executes each instruction sequentially
    /// 4. Enforces instruction count limit
    ///
    /// Returns an error if:
    /// - Instruction limit exceeded
    /// - Stack underflow/overflow
    /// - Division by zero (or Math domain error)
    /// - Invalid variable index
    pub fn execute(
        &mut self,
        program: &Program,
        context: &mut PresetContext,
    ) -> Result<(), VMError> {
        // Clear and pre-allocate stack
        self.stack.clear();
        self.stack.reserve(program.max_stack_depth);

        // Instruction counter (for safety)
        let mut instruction_count = 0;

        // Execute each instruction
        for instruction in &program.instructions {
            // Safety check: instruction limit
            instruction_count += 1;
            if instruction_count > self.max_instructions {
                return Err(VMError::InstructionLimitExceeded(self.max_instructions));
            }

            // Execute single instruction
            self.execute_instruction(instruction, context)?;
        }

        Ok(())
    }

    /// Execute a single bytecode instruction.
    ///
    /// This is the heart of the VM. Each instruction manipulates the stack
    /// and/or the variable context.
    #[inline]
    fn execute_instruction(
        &mut self,
        instruction: &Instruction,
        context: &mut PresetContext,
    ) -> Result<(), VMError> {
        match instruction {
            // === Stack Operations ===
            Instruction::Push(value) => {
                // Push literal onto stack
                self.stack.push(*value);
            }

            // === Variable Operations ===
            Instruction::LoadVar(idx) => {
                // Load variable value and push onto stack
                let value = context.get_var(*idx)?;
                self.stack.push(value);
            }

            Instruction::StoreVar(idx) => {
                // Pop value from stack and store in variable
                let value = self.pop()?;
                context.set_var(*idx, value)?;
            }

            // === Arithmetic Operations (Binary) ===
            Instruction::Add => {
                // Pop b, pop a, push a+b
                let b = self.pop()?;
                let a = self.pop()?;
                self.stack.push(a + b);
            }

            Instruction::Sub => {
                // Pop b, pop a, push a-b
                let b = self.pop()?;
                let a = self.pop()?;
                self.stack.push(a - b);
            }

            Instruction::Mul => {
                // Pop b, pop a, push a*b
                let b = self.pop()?;
                let a = self.pop()?;
                self.stack.push(a * b);
            }

            Instruction::Div => {
                // Pop b, pop a, push a/b
                let b = self.pop()?;
                let a = self.pop()?;

                // Safety: Check for division by zero
                if b.abs() < 1e-10 {
                    // Option 1: Return error
                    // return Err(VMError::DivisionByZero);

                    // Option 2: Return 0.0 (more forgiving, matches ns-eel2)
                    self.stack.push(0.0);
                } else {
                    self.stack.push(a / b);
                }
            }

            // === Unary Operations ===
            Instruction::Neg => {
                // Pop a, push -a
                let a = self.pop()?;
                self.stack.push(-a);
            }

            // === Built-in Functions ===
            Instruction::Sin => {
                // Pop x, push sin(x)
                let x = self.pop()?;
                self.stack.push(x.sin());
            }

            Instruction::Cos => {
                // Pop x, push cos(x)
                let x = self.pop()?;
                self.stack.push(x.cos());
            }

            Instruction::Sqrt => {
                // Pop x, push sqrt(x)
                let x = self.pop()?;

                // Safety: sqrt of negative returns 0.0 (forgiving)
                if x < 0.0 {
                    self.stack.push(0.0);
                } else {
                    self.stack.push(x.sqrt());
                }
            }

            Instruction::Abs => {
                // Pop x, push abs(x)
                let x = self.pop()?;
                self.stack.push(x.abs());
            }

            // Phase 2: More instructions would go here
        }

        Ok(())
    }

    /// Pop a value from the stack.
    ///
    /// Returns an error if the stack is empty (stack underflow).
    #[inline]
    fn pop(&mut self) -> Result<f32, VMError> {
        self.stack.pop().ok_or(VMError::StackUnderflow)
    }

    /// Get the current stack depth (for debugging).
    pub fn stack_depth(&self) -> usize {
        self.stack.len()
    }

    /// Clear the stack (for reuse).
    pub fn clear(&mut self) {
        self.stack.clear();
    }
}

impl Default for VM {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::context::{BASS_INDEX, MID_INDEX, Q1_INDEX};
    use crate::eval::bytecode::Instruction;

    #[test]
    fn test_vm_creation() {
        let vm = VM::new();
        assert_eq!(vm.max_instructions, VM::DEFAULT_MAX_INSTRUCTIONS);
        assert_eq!(vm.stack_depth(), 0);
    }

    #[test]
    fn test_execute_push() {
        let program = Program::new(vec![Instruction::Push(42.0)]);

        let mut ctx = PresetContext::new();
        let mut vm = VM::new();

        vm.execute(&program, &mut ctx).unwrap();

        // Value should be on stack (but not accessible from outside)
        // This is more of an internal test
        assert_eq!(vm.stack_depth(), 1);
        assert_eq!(vm.stack[0], 42.0);
    }

    #[test]
    fn test_execute_load_var() {
        let program = Program::new(vec![Instruction::LoadVar(BASS_INDEX)]);

        let mut ctx = PresetContext::new();
        ctx.bass = 0.8;
        ctx.sync_to_array();

        let mut vm = VM::new();
        vm.execute(&program, &mut ctx).unwrap();

        assert_eq!(vm.stack[0], 0.8);
    }

    #[test]
    fn test_execute_store_var() {
        let program = Program::new(vec![Instruction::Push(3.14), Instruction::StoreVar(Q1_INDEX)]);

        let mut ctx = PresetContext::new();
        ctx.sync_to_array();

        let mut vm = VM::new();
        vm.execute(&program, &mut ctx).unwrap();
        ctx.sync_from_array();

        assert_eq!(ctx.q[0], 3.14);
    }

    #[test]
    fn test_execute_add() {
        // 2 + 3 = 5
        let program = Program::new(vec![
            Instruction::Push(2.0),
            Instruction::Push(3.0),
            Instruction::Add,
        ]);

        let mut ctx = PresetContext::new();
        let mut vm = VM::new();

        vm.execute(&program, &mut ctx).unwrap();

        assert_eq!(vm.stack[0], 5.0);
    }

    #[test]
    fn test_execute_mul() {
        // 4 * 5 = 20
        let program = Program::new(vec![
            Instruction::Push(4.0),
            Instruction::Push(5.0),
            Instruction::Mul,
        ]);

        let mut ctx = PresetContext::new();
        let mut vm = VM::new();

        vm.execute(&program, &mut ctx).unwrap();

        assert_eq!(vm.stack[0], 20.0);
    }

    #[test]
    fn test_execute_neg() {
        // -5 = -5
        let program = Program::new(vec![Instruction::Push(5.0), Instruction::Neg]);

        let mut ctx = PresetContext::new();
        let mut vm = VM::new();

        vm.execute(&program, &mut ctx).unwrap();

        assert_eq!(vm.stack[0], -5.0);
    }

    #[test]
    fn test_execute_sin() {
        // sin(0) = 0
        let program = Program::new(vec![Instruction::Push(0.0), Instruction::Sin]);

        let mut ctx = PresetContext::new();
        let mut vm = VM::new();

        vm.execute(&program, &mut ctx).unwrap();

        assert!((vm.stack[0] - 0.0).abs() < 1e-6);
    }

    #[test]
    fn test_execute_division_by_zero() {
        // 5 / 0 = 0 (forgiving)
        let program = Program::new(vec![
            Instruction::Push(5.0),
            Instruction::Push(0.0),
            Instruction::Div,
        ]);

        let mut ctx = PresetContext::new();
        let mut vm = VM::new();

        vm.execute(&program, &mut ctx).unwrap();

        assert_eq!(vm.stack[0], 0.0);
    }

    #[test]
    fn test_execute_sqrt_negative() {
        // sqrt(-1) = 0 (forgiving)
        let program = Program::new(vec![Instruction::Push(-1.0), Instruction::Sqrt]);

        let mut ctx = PresetContext::new();
        let mut vm = VM::new();

        vm.execute(&program, &mut ctx).unwrap();

        assert_eq!(vm.stack[0], 0.0);
    }

    #[test]
    fn test_execute_complex_expression() {
        // bass + mid * 0.5
        // Bytecode: LoadVar(bass), LoadVar(mid), Push(0.5), Mul, Add
        let program = Program::new(vec![
            Instruction::LoadVar(BASS_INDEX),
            Instruction::LoadVar(MID_INDEX),
            Instruction::Push(0.5),
            Instruction::Mul,
            Instruction::Add,
        ]);

        let mut ctx = PresetContext::new();
        ctx.bass = 0.8;
        ctx.mid = 0.6;
        ctx.sync_to_array();

        let mut vm = VM::new();
        vm.execute(&program, &mut ctx).unwrap();

        // Result: 0.8 + 0.6 * 0.5 = 0.8 + 0.3 = 1.1
        assert!((vm.stack[0] - 1.1).abs() < 1e-6);
    }

    #[test]
    fn test_execute_assignment() {
        // q1 = bass + mid
        let program = Program::new(vec![
            Instruction::LoadVar(BASS_INDEX),
            Instruction::LoadVar(MID_INDEX),
            Instruction::Add,
            Instruction::StoreVar(Q1_INDEX),
        ]);

        let mut ctx = PresetContext::new();
        ctx.bass = 0.7;
        ctx.mid = 0.3;
        ctx.sync_to_array();

        let mut vm = VM::new();
        vm.execute(&program, &mut ctx).unwrap();
        ctx.sync_from_array();

        assert!((ctx.q[0] - 1.0).abs() < 1e-6);
    }

    #[test]
    fn test_stack_underflow() {
        // Try to pop from empty stack
        let program = Program::new(vec![Instruction::Add]);

        let mut ctx = PresetContext::new();
        let mut vm = VM::new();

        assert!(matches!(
            vm.execute(&program, &mut ctx),
            Err(VMError::StackUnderflow)
        ));
    }

    #[test]
    fn test_instruction_limit() {
        // Create a program with too many instructions
        let mut instructions = Vec::new();
        for _ in 0..20_000 {
            instructions.push(Instruction::Push(1.0));
        }
        let program = Program::new(instructions);

        let mut ctx = PresetContext::new();
        let mut vm = VM::new();

        // Should hit instruction limit
        assert!(matches!(
            vm.execute(&program, &mut ctx),
            Err(VMError::InstructionLimitExceeded(_))
        ));
    }
}

