----- FILE: ./crates/milkdropper-preset/src/eval/compiler.rs -----
//! Compiler: AST → Bytecode.
//!
//! The compiler transforms Abstract Syntax Trees into efficient bytecode
//! that can be executed by the VM. It performs a post-order traversal of
//! the AST and emits stack-based instructions.
//!
//! ## Example
//!
//! ```
//! use milkdropper_preset::eval::{Parser, Compiler};
//!
//! // Parse expression
//! let mut parser = Parser::from_str("bass + mid * 0.5");
//! let ast = parser.parse().unwrap();
//!
//! // Compile to bytecode
//! let compiler = Compiler::new();
//! let program = compiler.compile(&ast).unwrap();
//!
//! // Program now contains executable bytecode
//! println!("{}", program.disassemble());
//! ```

use crate::error::PresetError;
use crate::eval::ast::{BinOpKind, Expr, UnaryOpKind};
use crate::eval::bytecode::{Instruction, Program};
use crate::eval::builtins::BuiltinFunc;

/// Bytecode compiler.
///
/// The compiler is stateless and can be reused for multiple compilations.
pub struct Compiler {
    // Currently stateless, but we might add optimization passes later
}

impl Compiler {
    /// Create a new compiler.
    pub fn new() -> Self {
        Self {}
    }

    /// Compile an AST expression into a bytecode program.
    ///
    /// This is the main entry point for compilation.
    ///
    /// ```
    /// use milkdropper_preset::eval::{Parser, Compiler};
    ///
    /// let mut parser = Parser::from_str("q1 = bass + mid");
    /// let ast = parser.parse().unwrap();
    ///
    /// let compiler = Compiler::new();
    /// let program = compiler.compile(&ast).unwrap();
    /// ```
    #[allow(dead_code)] // Used in tests
    pub fn compile(&self, expr: &Expr) -> Result<Program, PresetError> {
        let mut instructions = Vec::new();
        Self::compile_expr_internal(expr, &mut instructions)?;
        Ok(Program::new(instructions))
    }

    /// Compile an expression with source information.
    pub fn compile_with_source(&self, expr: &Expr, source: String) -> Result<Program, PresetError> {
        let mut instructions = Vec::new();
        Self::compile_expr_internal(expr, &mut instructions)?;
        Ok(Program::with_source(instructions, source))
    }

    /// Compile an expression recursively.
    ///
    /// This performs a post-order traversal of the AST:
    /// 1. Compile children first (left, then right for binary ops)
    /// 2. Emit instruction for this node
    ///
    /// This naturally produces stack-based bytecode.
    ///
    /// Note: This is a static method to avoid clippy warning about
    /// only_used_in_recursion.
    fn compile_expr_internal(
        expr: &Expr,
        instructions: &mut Vec<Instruction>,
    ) -> Result<(), PresetError> {
        match expr {
            // === Literals ===
            Expr::Literal(value) => {
                // Emit: Push(value)
                instructions.push(Instruction::Push(*value));
            }

            // === Variables ===
            Expr::Variable(var_ref) => {
                // Emit: LoadVar(index)
                let idx = var_ref.to_index();
                instructions.push(Instruction::LoadVar(idx));
            }

            // === Binary Operations ===
            Expr::BinOp(op, left, right) => {
                // Compile left operand (pushes value onto stack)
                Self::compile_expr_internal(left, instructions)?;

                // Compile right operand (pushes value onto stack)
                Self::compile_expr_internal(right, instructions)?;

                // Emit operation (pops 2, pushes 1)
                let instr = match op {
                    BinOpKind::Add => Instruction::Add,
                    BinOpKind::Sub => Instruction::Sub,
                    BinOpKind::Mul => Instruction::Mul,
                    BinOpKind::Div => Instruction::Div,
                };
                instructions.push(instr);
            }

            // === Unary Operations ===
            Expr::UnaryOp(op, operand) => {
                // Compile operand (pushes value onto stack)
                Self::compile_expr_internal(operand, instructions)?;

                // Emit operation (pops 1, pushes 1)
                let instr = match op {
                    UnaryOpKind::Neg => Instruction::Neg,
                };
                instructions.push(instr);
            }

            // === Function Calls ===
            Expr::FuncCall(name, args) => {
                // Parse function name
                let func = BuiltinFunc::from_str(name).ok_or_else(|| {
                    PresetError::UnknownFunction(name.clone())
                })?;

                // Check argument count
                let expected_args = func.arg_count();
                if args.len() != expected_args {
                    return Err(PresetError::Compile(format!(
                        "Function {} expects {} arguments, found {}",
                        name,
                        expected_args,
                        args.len()
                    )));
                }

                // Compile arguments (push onto stack in order)
                for arg in args {
                    Self::compile_expr_internal(arg, instructions)?;
                }

                // Emit function instruction
                let instr = func.to_instruction();
                instructions.push(instr);
            }

            // === Assignment ===
            Expr::Assign(var_ref, value) => {
                // Compile value expression (pushes result onto stack)
                Self::compile_expr_internal(value, instructions)?;

                // Emit: StoreVar(index)
                // Note: StoreVar pops the value but also leaves a copy on the stack
                // (for chained assignments like: q2 = q1 = bass)
                // Actually, for simplicity, we'll just pop for now
                let idx = var_ref.to_index();
                instructions.push(Instruction::StoreVar(idx));
            }
        }

        Ok(())
    }
}

impl Default for Compiler {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::eval::Parser;

    #[test]
    fn test_compile_literal() {
        let mut parser = Parser::from_str("42");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        let program = compiler.compile(&ast).unwrap();

        assert_eq!(program.instructions.len(), 1);
        assert!(matches!(program.instructions[0], Instruction::Push(42.0)));
    }

    #[test]
    fn test_compile_variable() {
        let mut parser = Parser::from_str("bass");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        let program = compiler.compile(&ast).unwrap();

        assert_eq!(program.instructions.len(), 1);
        assert!(matches!(program.instructions[0], Instruction::LoadVar(_)));
    }

    #[test]
    fn test_compile_binop() {
        let mut parser = Parser::from_str("bass + mid");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        let program = compiler.compile(&ast).unwrap();

        // Should be: LoadVar(bass), LoadVar(mid), Add
        assert_eq!(program.instructions.len(), 3);
        assert!(matches!(program.instructions[0], Instruction::LoadVar(_)));
        assert!(matches!(program.instructions[1], Instruction::LoadVar(_)));
        assert!(matches!(program.instructions[2], Instruction::Add));
    }

    #[test]
    fn test_compile_binop_precedence() {
        // bass + mid * 2 -> LoadVar(bass), LoadVar(mid), Push(2), Mul, Add
        let mut parser = Parser::from_str("bass + mid * 2");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        let program = compiler.compile(&ast).unwrap();

        assert_eq!(program.instructions.len(), 5);
        // Load bass
        assert!(matches!(program.instructions[0], Instruction::LoadVar(_)));
        // Load mid
        assert!(matches!(program.instructions[1], Instruction::LoadVar(_)));
        // Push 2
        assert!(matches!(program.instructions[2], Instruction::Push(2.0)));
        // Multiply mid * 2
        assert!(matches!(program.instructions[3], Instruction::Mul));
        // Add bass + (mid * 2)
        assert!(matches!(program.instructions[4], Instruction::Add));
    }

    #[test]
    fn test_compile_unary_neg() {
        let mut parser = Parser::from_str("-bass");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        let program = compiler.compile(&ast).unwrap();

        // Should be: LoadVar(bass), Neg
        assert_eq!(program.instructions.len(), 2);
        assert!(matches!(program.instructions[0], Instruction::LoadVar(_)));
        assert!(matches!(program.instructions[1], Instruction::Neg));
    }

    #[test]
    fn test_compile_function_call() {
        let mut parser = Parser::from_str("sin(bass)");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        let program = compiler.compile(&ast).unwrap();

        // Should be: LoadVar(bass), Sin
        assert_eq!(program.instructions.len(), 2);
        assert!(matches!(program.instructions[0], Instruction::LoadVar(_)));
        assert!(matches!(program.instructions[1], Instruction::Sin));
    }

    #[test]
    fn test_compile_assignment() {
        let mut parser = Parser::from_str("q1 = bass + mid");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        let program = compiler.compile(&ast).unwrap();

        // Should be: LoadVar(bass), LoadVar(mid), Add, StoreVar(q1)
        assert_eq!(program.instructions.len(), 4);
        assert!(matches!(program.instructions[0], Instruction::LoadVar(_)));
        assert!(matches!(program.instructions[1], Instruction::LoadVar(_)));
        assert!(matches!(program.instructions[2], Instruction::Add));
        assert!(matches!(program.instructions[3], Instruction::StoreVar(_)));
    }

    #[test]
    fn test_compile_complex() {
        // q1 = sin(bass + mid) * 0.5
        let mut parser = Parser::from_str("q1 = sin(bass + mid) * 0.5");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        let program = compiler.compile(&ast).unwrap();

        // LoadVar(bass), LoadVar(mid), Add, Sin, Push(0.5), Mul, StoreVar(q1)
        assert_eq!(program.instructions.len(), 7);
    }

    #[test]
    fn test_compile_unknown_function() {
        let mut parser = Parser::from_str("unknown(bass)");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        assert!(compiler.compile(&ast).is_err());
    }

    #[test]
    fn test_compile_wrong_arg_count() {
        // sin expects 1 argument
        let mut parser = Parser::from_str("sin(bass, mid)");
        let ast = parser.parse().unwrap();

        let compiler = Compiler::new();
        assert!(compiler.compile(&ast).is_err());
    }
}

