//! Bytecode instruction set and program representation.
//!
//! This module defines the bytecode that the VM executes. The bytecode
//! is compiled from the AST and provides fast execution with minimal overhead.
//!
//! ## Instruction Set Design
//!
//! The instruction set is stack-based (like the JVM or WASM):
//! - Instructions pop operands from the stack
//! - Results are pushed back onto the stack
//! - Very simple to implement and optimize
//!
//! ## Example
//!
//! Expression: `bass + mid * 0.5`
//!
//! Bytecode:
//! ```text
//! LoadVar(BASS_INDEX)   // Push bass onto stack
//! LoadVar(MID_INDEX)    // Push mid onto stack
//! Push(0.5)             // Push 0.5 onto stack
//! Mul                   // Pop 0.5 and mid, push mid*0.5
//! Add                   // Pop mid*0.5 and bass, push bass+mid*0.5
//! ```

use crate::context::VarIndex;

/// Bytecode instruction.
///
/// Each instruction is a single operation that the VM executes.
/// Most instructions operate on the stack.
#[derive(Debug, Clone, PartialEq)]
pub enum Instruction {
    // === Stack Operations ===
    /// Push literal value onto stack
    Push(f32),

    // === Variable Operations ===
    /// Load variable value and push onto stack
    LoadVar(VarIndex),

    /// Pop value from stack and store in variable
    StoreVar(VarIndex),

    // === Arithmetic Operations (Binary) ===
    /// Pop b, pop a, push a+b
    Add,

    /// Pop b, pop a, push a-b
    Sub,

    /// Pop b, pop a, push a*b
    Mul,

    /// Pop b, pop a, push a/b (with division-by-zero check)
    Div,

    // === Unary Operations ===
    /// Pop a, push -a
    Neg,

    // === Built-in Functions ===
    /// Pop x, push sin(x)
    Sin,

    /// Pop x, push cos(x)
    Cos,

    /// Pop x, push sqrt(x) (with negative check)
    Sqrt,

    /// Pop x, push abs(x)
    Abs,

    // Phase 2: More functions
    // Pow,      // Pop exp, pop base, push base^exp
    // Atan2,    // Pop x, pop y, push atan2(y, x)
    // Min,      // Pop b, pop a, push min(a, b)
    // Max,      // Pop b, pop a, push max(a, b)

    // Phase 2: Control flow
    // Jump(offset),      // Unconditional jump
    // JumpIf(offset),    // Pop condition, jump if true
}

/// Compiled bytecode program.
///
/// This represents a complete compiled expression ready for execution.
///
/// The program includes metadata like max stack depth which allows
/// the VM to pre-allocate the stack efficiently.
#[derive(Debug, Clone)]
pub struct Program {
    /// Bytecode instructions
    pub instructions: Vec<Instruction>,

    /// Maximum stack depth needed (for pre-allocation)
    pub max_stack_depth: usize,

    /// Source expression (for debugging)
    pub source: Option<String>,
}

impl Program {
    /// Create a new program with the given instructions.
    ///
    /// The max stack depth is calculated automatically.
    pub fn new(instructions: Vec<Instruction>) -> Self {
        let max_stack_depth = Self::calculate_max_stack_depth(&instructions);
        Self {
            instructions,
            max_stack_depth,
            source: None,
        }
    }

    /// Create a new program with source information.
    pub fn with_source(instructions: Vec<Instruction>, source: String) -> Self {
        let max_stack_depth = Self::calculate_max_stack_depth(&instructions);
        Self {
            instructions,
            max_stack_depth,
            source: Some(source),
        }
    }

    /// Calculate the maximum stack depth needed for this program.
    ///
    /// This allows the VM to pre-allocate the exact amount of stack space
    /// needed, avoiding dynamic allocations during execution.
    ///
    /// Algorithm: Simulate execution and track stack depth.
    fn calculate_max_stack_depth(instructions: &[Instruction]) -> usize {
        let mut current_depth = 0;
        let mut max_depth = 0;

        for instr in instructions {
            // Calculate stack effect of this instruction
            let stack_effect = match instr {
                // Push operations increase depth by 1
                Instruction::Push(_) => 1,
                Instruction::LoadVar(_) => 1,

                // Pop operations decrease depth by 1
                Instruction::StoreVar(_) => -1,

                // Binary operations: pop 2, push 1 (net -1)
                Instruction::Add
                | Instruction::Sub
                | Instruction::Mul
                | Instruction::Div => -1,

                // Unary operations: pop 1, push 1 (net 0)
                Instruction::Neg
                | Instruction::Sin
                | Instruction::Cos
                | Instruction::Sqrt
                | Instruction::Abs => 0,
            };

            current_depth = (current_depth as isize + stack_effect).max(0) as usize;
            max_depth = max_depth.max(current_depth);
        }

        max_depth
    }

    /// Get the number of instructions in this program.
    pub fn len(&self) -> usize {
        self.instructions.len()
    }

    /// Check if the program is empty.
    pub fn is_empty(&self) -> bool {
        self.instructions.is_empty()
    }

    /// Pretty-print the program for debugging.
    pub fn disassemble(&self) -> String {
        let mut output = String::new();

        if let Some(source) = &self.source {
            output.push_str(&format!("// Source: {}\n", source));
        }

        output.push_str(&format!(
            "// Max stack depth: {}\n",
            self.max_stack_depth
        ));
        output.push_str(&format!("// Instructions: {}\n\n", self.len()));

        for (i, instr) in self.instructions.iter().enumerate() {
            output.push_str(&format!("{:4} {:?}\n", i, instr));
        }

        output
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_program_creation() {
        let instructions = vec![
            Instruction::Push(1.0),
            Instruction::Push(2.0),
            Instruction::Add,
        ];

        let program = Program::new(instructions);
        assert_eq!(program.len(), 3);
        assert_eq!(program.max_stack_depth, 2); // Push, Push = depth 2
    }

    #[test]
    fn test_max_stack_depth_calculation() {
        // Expression: bass + mid * 0.5
        // LoadVar(bass), LoadVar(mid), Push(0.5), Mul, Add
        // Stack: [bass] -> [bass, mid] -> [bass, mid, 0.5] -> [bass, mid*0.5] -> [bass+mid*0.5]
        // Max depth: 3 (when bass, mid, and 0.5 are all on stack)
        let instructions = vec![
            Instruction::LoadVar(VarIndex(0)), // bass
            Instruction::LoadVar(VarIndex(1)), // mid
            Instruction::Push(0.5),
            Instruction::Mul,
            Instruction::Add,
        ];

        let program = Program::new(instructions);
        assert_eq!(program.max_stack_depth, 3);
    }

    #[test]
    fn test_program_disassembly() {
        let instructions = vec![Instruction::Push(1.0), Instruction::Push(2.0), Instruction::Add];

        let program = Program::with_source(instructions, "1 + 2".to_string());
        let disasm = program.disassemble();

        assert!(disasm.contains("Source: 1 + 2"));
        assert!(disasm.contains("Max stack depth: 2"));
        assert!(disasm.contains("Push(1.0)"));
        assert!(disasm.contains("Add"));
    }

    #[test]
    fn test_empty_program() {
        let program = Program::new(vec![]);
        assert!(program.is_empty());
        assert_eq!(program.len(), 0);
        assert_eq!(program.max_stack_depth, 0);
    }
}

