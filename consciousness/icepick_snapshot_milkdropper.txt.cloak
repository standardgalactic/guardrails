//! Expression evaluation subsystem.
//!
//! This module contains the complete expression evaluator:
//! - Lexer: Text → Tokens
//! - Parser: Tokens → AST
//! - Compiler: AST → Bytecode
//! - VM: Execute bytecode
//! - Built-ins: Math functions

pub mod lexer;
pub mod ast;
pub mod parser;
pub mod bytecode;
pub mod compiler;
pub mod vm;
pub mod builtins;

// Re-export commonly used types (used by public API and tests)
pub use parser::Parser;
pub use compiler::Compiler;

