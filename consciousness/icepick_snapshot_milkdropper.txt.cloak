## 4. Preset Types

### 4.1 `Preset` - Loaded Preset

```rust
/// A loaded and compiled preset.
///
/// Created by parsing a .milk file or programmatically.
#[derive(Debug, Clone)]
pub struct Preset {
    /// Preset name
    pub name: String,

    /// Preset metadata
    pub metadata: PresetMetadata,

    // Private fields for compiled expressions, shaders, etc.
}

impl Preset {
    /// Parses a preset from a .milk file string.
    ///
    /// # Errors
    ///
    /// Returns an error if:
    /// - Format is invalid
    /// - Expression compilation fails
    /// - Shader compilation fails
    pub fn parse(content: &str) -> Result<Self, PresetError>;

    /// Parses a preset from a file.
    pub fn from_file<P: AsRef<Path>>(path: P)
        -> Result<Self, PresetError>;

    /// Gets preset metadata.
    pub fn metadata(&self) -> &PresetMetadata;

    /// Gets the number of custom waves.
    pub fn wave_count(&self) -> usize;

    /// Gets the number of custom shapes.
    pub fn shape_count(&self) -> usize;

    /// Checks if preset has custom shaders.
    pub fn has_shaders(&self) -> bool;
}

/// Preset metadata.
#[derive(Debug, Clone)]
pub struct PresetMetadata {
    /// Preset name
    pub name: String,

    /// Author (if specified)
    pub author: Option<String>,

    /// Description (if specified)
    pub description: Option<String>,

    /// Preset version
    pub version: Option<String>,

    /// Shader version required
    pub shader_version: ShaderVersion,
}
```

---

### 4.2 `PresetEngine` - Preset Evaluation

```rust
/// Preset engine that evaluates expressions and manages state.
///
/// Most users should use `Visualizer` instead.
pub struct PresetEngine {
    // Private fields
}

impl PresetEngine {
    /// Creates a new preset engine.
    pub fn new() -> Self;

    /// Creates with custom configuration.
    pub fn with_config(config: PresetConfig) -> Self;

    /// Loads a preset.
    pub fn load(&mut self, preset: Preset)
        -> Result<(), PresetError>;

    /// Updates preset state from audio frame.
    ///
    /// Evaluates per-frame expressions and updates state.
    pub fn update(&mut self, audio: &AudioFrame)
        -> Result<(), PresetError>;

    /// Gets the current preset state.
    pub fn state(&self) -> &PresetState;

    /// Gets a mutable reference to preset state.
    ///
    /// Allows manual modification of state variables.
    pub fn state_mut(&mut self) -> &mut PresetState;

    /// Resets preset state to defaults.
    pub fn reset(&mut self);
}
```

---

### 4.3 `PresetState` - Runtime State

```rust
/// Preset runtime state.
///
/// Contains all preset variables and parameters.
#[derive(Debug, Clone)]
pub struct PresetState {
    // Core parameters (blendable)
    pub zoom: f32,
    pub rot: f32,
    pub warp: f32,
    pub cx: f32,
    pub cy: f32,
    pub dx: f32,
    pub dy: f32,
    pub sx: f32,
    pub sy: f32,

    // Wave parameters
    pub wave_alpha: f32,
    pub wave_scale: f32,
    pub wave_smoothing: f32,
    pub wave_mystery: f32,

    // Motion parameters
    pub ob_size: f32,
    pub ob_r: f32,
    pub ob_g: f32,
    pub ob_a: f32,
    pub ib_size: f32,
    pub ib_r: f32,
    pub ib_g: f32,
    pub ib_a: f32,

    // User variables
    pub q_vars: [f64; 32],  // q1-q32
    pub t_vars: [f64; 8],   // t1-t8

    // Time
    pub time: f64,
    pub fps: f32,

    // Audio (injected from AudioFrame)
    pub bass: f32,
    pub mid: f32,
    pub treb: f32,
    pub bass_att: f32,
    pub mid_att: f32,
    pub treb_att: f32,
}

impl PresetState {
    /// Creates a new preset state with default values.
    pub fn new() -> Self;

    /// Gets a variable by name.
    ///
    /// # Examples
    ///
    /// ```
    /// let zoom = state.get_var("zoom").unwrap();
    /// let q1 = state.get_var("q1").unwrap();
    /// ```
    pub fn get_var(&self, name: &str) -> Option<f64>;

    /// Sets a variable by name.
    pub fn set_var(&mut self, name: &str, value: f64) -> Result<(), PresetError>;

    /// Injects audio frame values.
    ///
    /// Called automatically by `PresetEngine::update()`.
    pub fn inject_audio(&mut self, audio: &AudioFrame);
}
```

---

## 5. Rendering Types

### 5.1 `RenderFrame` - Rendered Output

```rust
/// A rendered frame of visualization.
///
/// Contains pixel data ready for display.
#[derive(Debug, Clone)]
pub struct RenderFrame {
    /// Pixel data (RGBA8 format)
    pub pixels: Vec<u8>,

    /// Frame width
    pub width: u32,

    /// Frame height
    pub height: u32,

    /// Frame timestamp (seconds since start)
    pub timestamp: f64,
}

impl RenderFrame {
    /// Creates an empty (black) frame.
    pub fn empty(width: u32, height: u32) -> Self {
        RenderFrame {
            pixels: vec![0; (width * height * 4) as usize],
            width,
            height,
            timestamp: 0.0,
        }
    }

    /// Gets the pixel data as a slice.
    pub fn as_slice(&self) -> &[u8] {
        &self.pixels
    }

    /// Gets the pixel data as a mutable slice.
    pub fn as_mut_slice(&mut self) -> &mut [u8] {
        &mut self.pixels
    }

    /// Saves frame as PNG.
    #[cfg(feature = "image")]
    pub fn save_png<P: AsRef<Path>>(&self, path: P)
        -> Result<(), std::io::Error>;

    /// Converts to image crate's DynamicImage.
    #[cfg(feature = "image")]
    pub fn to_image(&self) -> image::DynamicImage;
}
```

---

### 5.2 `Renderer` - Low-Level Rendering

```rust
/// Low-level renderer.
///
/// Most users should use `Visualizer` instead.
pub struct Renderer {
    // Private fields
}

impl Renderer {
    /// Creates a new renderer with the given backend.
    pub fn new(backend: RenderBackend)
        -> Result<Self, RenderError>;

    /// Creates with auto-detected backend.
    pub fn auto() -> Result<Self, RenderError> {
        Self::new(RenderBackend::Auto)
    }

    /// Creates with custom configuration.
    pub fn with_config(config: RenderConfig)
        -> Result<Self, RenderError>;

    /// Renders a frame from preset state.
    pub fn render(&mut self, state: &PresetState)
        -> Result<RenderFrame, RenderError>;

    /// Gets the current backend type.
    pub fn backend_type(&self) -> RenderBackendType;

    /// Resizes the output resolution.
    pub fn resize(&mut self, width: u32, height: u32)
        -> Result<(), RenderError>;
}
```

