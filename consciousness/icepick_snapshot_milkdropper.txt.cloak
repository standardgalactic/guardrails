----- FILE: ./crates/milkdropper-audio/benches/marine_bench.rs -----
//! Performance benchmarks for Phoenix Marine audio analysis
//!
//! This benchmark suite measures the performance of the Phoenix Marine algorithm
//! to ensure it meets the <100μs target (ideally <50μs) per frame.
//!
//! ## Running Benchmarks
//!
//! ```bash
//! cd crates/milkdropper-audio
//! cargo bench
//! ```
//!
//! ## Interpreting Results
//!
//! Target performance for 576 samples @ 192kHz:
//! - **Excellent**: <50μs (10x faster than FFT)
//! - **Good**: <75μs (6-7x faster than FFT)
//! - **Acceptable**: <100μs (5x faster than FFT)
//! - **Needs work**: >100μs (approaching FFT performance)
//!
//! ## Sample Rates Tested
//!
//! - 44100 Hz (CD quality)
//! - 48000 Hz (Professional audio)
//! - 96000 Hz (High-resolution audio)
//! - 192000 Hz (Ultra-high resolution, our target)

use criterion::{black_box, criterion_group, criterion_main, BenchmarkId, Criterion, Throughput};
use milkdropper_audio::AudioAnalyzer;
use std::f32::consts::PI;

// ============================================================================
// Helper Functions
// ============================================================================

/// Generate a sine wave at the given frequency
fn sine_wave(freq: f32, sample_rate: f32, num_samples: usize) -> Vec<f32> {
    (0..num_samples)
        .map(|i| {
            let t = i as f32 / sample_rate;
            (2.0 * PI * freq * t).sin()
        })
        .collect()
}

/// Generate white noise (random samples)
fn white_noise(num_samples: usize) -> Vec<f32> {
    use std::collections::hash_map::RandomState;
    use std::hash::{BuildHasher, Hasher};

    let hasher = RandomState::new();
    (0..num_samples)
        .map(|i| {
            let mut h = hasher.build_hasher();
            h.write_usize(i);
            let val = h.finish();
            // Convert to -1.0..1.0 range
            ((val as f32 / u64::MAX as f32) * 2.0) - 1.0
        })
        .collect()
}

// ============================================================================
// Core Benchmark: analyze_frame at different sample rates
// ============================================================================

fn bench_analyze_frame(c: &mut Criterion) {
    let mut group = c.benchmark_group("analyze_frame");

    // Test different sample rates
    let sample_rates = [44100, 48000, 96000, 192000];

    for sample_rate in sample_rates.iter() {
        // Create analyzer for this sample rate
        let mut analyzer = AudioAnalyzer::new(*sample_rate);

        // Generate test signal (576 samples of a mixed tone)
        let samples = sine_wave(100.0, *sample_rate as f32, 576);

        // Set throughput (for "elements per second" metric)
        group.throughput(Throughput::Elements(576));

        // Benchmark
        group.bench_with_input(
            BenchmarkId::from_parameter(sample_rate),
            &samples,
            |b, samples| {
                b.iter(|| {
                    let frame = analyzer.analyze(black_box(samples));
                    black_box(frame);
                })
            },
        );
    }

    group.finish();
}

// ============================================================================
// Buffer Size Scaling
// ============================================================================

fn bench_buffer_sizes(c: &mut Criterion) {
    let mut group = c.benchmark_group("buffer_sizes");

    let sample_rate = 192000;
    let buffer_sizes = [256, 512, 576, 1024, 2048];

    for size in buffer_sizes.iter() {
        let mut analyzer = AudioAnalyzer::new(sample_rate);
        let samples = sine_wave(440.0, sample_rate as f32, *size);

        group.throughput(Throughput::Elements(*size as u64));

        group.bench_with_input(BenchmarkId::from_parameter(size), &samples, |b, samples| {
            b.iter(|| {
                let frame = analyzer.analyze(black_box(samples));
                black_box(frame);
            })
        });
    }

    group.finish();
}

// ============================================================================
// Signal Type Comparison
// ============================================================================

fn bench_signal_types(c: &mut Criterion) {
    let mut group = c.benchmark_group("signal_types");
    group.throughput(Throughput::Elements(576));

    let sample_rate = 192000;
    let num_samples = 576;

    // Test different signal types
    let signals = [
        ("silence", vec![0.0; num_samples]),
        ("sine_100hz", sine_wave(100.0, sample_rate as f32, num_samples)),
        ("sine_1000hz", sine_wave(1000.0, sample_rate as f32, num_samples)),
        ("sine_5000hz", sine_wave(5000.0, sample_rate as f32, num_samples)),
        ("white_noise", white_noise(num_samples)),
    ];

    for (name, samples) in signals.iter() {
        let mut analyzer = AudioAnalyzer::new(sample_rate);

        group.bench_with_input(BenchmarkId::from_parameter(name), samples, |b, samples| {
            b.iter(|| {
                let frame = analyzer.analyze(black_box(samples));
                black_box(frame);
            })
        });
    }

    group.finish();
}

// ============================================================================
// Analyzer Creation Overhead
// ============================================================================

fn bench_analyzer_creation(c: &mut Criterion) {
    let mut group = c.benchmark_group("analyzer_creation");

    let sample_rates = [44100, 192000];

    for sample_rate in sample_rates.iter() {
        group.bench_with_input(
            BenchmarkId::from_parameter(sample_rate),
            sample_rate,
            |b, &sr| {
                b.iter(|| {
                    let analyzer = AudioAnalyzer::new(black_box(sr));
                    black_box(analyzer);
                })
            },
        );
    }

    group.finish();
}

// ============================================================================
// Reset Overhead
// ============================================================================

fn bench_reset(c: &mut Criterion) {
    let mut group = c.benchmark_group("reset");

    let sample_rate = 192000;

    group.bench_function("reset", |b| {
        let mut analyzer = AudioAnalyzer::new(sample_rate);
        b.iter(|| {
            analyzer.reset();
            black_box(&analyzer);
        })
    });

    group.finish();
}

// ============================================================================
// Continuous Processing (Realistic Workload)
// ============================================================================

fn bench_continuous_processing(c: &mut Criterion) {
    let mut group = c.benchmark_group("continuous_processing");
    group.throughput(Throughput::Elements(576));

    let sample_rate = 192000;

    // Simulate continuous audio stream
    // (Analyzer state carries over between frames, more realistic)
    group.bench_function("continuous_stream", |b| {
        let mut analyzer = AudioAnalyzer::new(sample_rate);
        let samples = sine_wave(440.0, sample_rate as f32, 576);

        b.iter(|| {
            // Process frame (state persists between iterations)
            let frame = analyzer.analyze(black_box(&samples));
            black_box(frame);
        })
    });

    group.finish();
}

// ============================================================================
// Worst-Case Scenario (Mixed Frequencies)
// ============================================================================

fn bench_worst_case(c: &mut Criterion) {
    let mut group = c.benchmark_group("worst_case");
    group.throughput(Throughput::Elements(576));

    let sample_rate = 192000;

    // Create a complex signal (mix of bass, mid, treble)
    let samples: Vec<f32> = (0..576)
        .map(|i| {
            let t = i as f32 / sample_rate as f32;
            // Mix of three frequencies
            0.33 * (2.0 * PI * 100.0 * t).sin()
                + 0.33 * (2.0 * PI * 1000.0 * t).sin()
                + 0.33 * (2.0 * PI * 5000.0 * t).sin()
        })
        .collect();

    let mut analyzer = AudioAnalyzer::new(sample_rate);

    group.bench_function("mixed_frequencies", |b| {
        b.iter(|| {
            let frame = analyzer.analyze(black_box(&samples));
            black_box(frame);
        })
    });

    group.finish();
}

// ============================================================================
// Comparison with Initialization Cost
// ============================================================================

fn bench_amortized_cost(c: &mut Criterion) {
    let mut group = c.benchmark_group("amortized_cost");
    group.throughput(Throughput::Elements(576 * 100)); // 100 frames

    let sample_rate = 192000;
    let samples = sine_wave(440.0, sample_rate as f32, 576);

    // Benchmark: Create analyzer + process 100 frames
    group.bench_function("create_and_process_100_frames", |b| {
        b.iter(|| {
            let mut analyzer = AudioAnalyzer::new(sample_rate);
            for _ in 0..100 {
                let frame = analyzer.analyze(black_box(&samples));
                black_box(frame);
            }
        })
    });

    // Benchmark: Just process 100 frames (analyzer already created)
    group.bench_function("process_100_frames_only", |b| {
        let mut analyzer = AudioAnalyzer::new(sample_rate);
        b.iter(|| {
            for _ in 0..100 {
                let frame = analyzer.analyze(black_box(&samples));
                black_box(frame);
            }
        })
    });

    group.finish();
}

// ============================================================================
// Register Benchmarks
// ============================================================================

criterion_group!(
    benches,
    bench_analyze_frame,
    bench_buffer_sizes,
    bench_signal_types,
    bench_analyzer_creation,
    bench_reset,
    bench_continuous_processing,
    bench_worst_case,
    bench_amortized_cost,
);

criterion_main!(benches);

