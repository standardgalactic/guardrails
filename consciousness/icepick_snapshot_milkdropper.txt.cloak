----- FILE: ./crates/milkdropper-audio/tests/analysis_tests.rs -----
//! Integration tests for Phoenix Marine audio analysis
//!
//! These tests verify end-to-end behavior of the AudioAnalyzer

use milkdropper_audio::AudioAnalyzer;
use std::f32::consts::PI;

// ============================================================================
// Test Helpers
// ============================================================================

/// Generate a pure sine wave
fn sine_wave(freq: f32, sample_rate: f32, num_samples: usize) -> Vec<f32> {
    (0..num_samples)
        .map(|i| {
            let t = i as f32 / sample_rate;
            (2.0 * PI * freq * t).sin()
        })
        .collect()
}

// ============================================================================
// Basic Tests
// ============================================================================

#[test]
fn test_analyzer_creation() {
    let analyzer = AudioAnalyzer::new(44100);
    assert_eq!(analyzer.sample_rate(), 44100);
}

#[test]
fn test_analyze_silence() {
    let mut analyzer = AudioAnalyzer::new(44100);
    let silence = vec![0.0; 576];

    let frame = analyzer.analyze(&silence);

    assert!(frame.bass < 0.05);
    assert!(frame.mid < 0.05);
    assert!(frame.treb < 0.05);
}

#[test]
fn test_bass_response() {
    let mut analyzer = AudioAnalyzer::new(44100);
    let bass_tone = sine_wave(100.0, 44100.0, 576);

    let frame = analyzer.analyze(&bass_tone);

    assert!(frame.bass > 0.3, "Bass should respond to 100 Hz");
    assert!(frame.mid < 0.5 * frame.bass);
    assert!(frame.treb < 0.3 * frame.bass);
}

#[test]
fn test_mid_response() {
    let mut analyzer = AudioAnalyzer::new(44100);
    let mid_tone = sine_wave(1000.0, 44100.0, 576);

    let frame = analyzer.analyze(&mid_tone);

    assert!(frame.mid > 0.3, "Mid should respond to 1000 Hz");
}

#[test]
fn test_treble_response() {
    let mut analyzer = AudioAnalyzer::new(44100);
    let treble_tone = sine_wave(5000.0, 44100.0, 576);

    let frame = analyzer.analyze(&treble_tone);

    assert!(frame.treb > 0.3, "Treble should respond to 5000 Hz");
}

#[test]
fn test_smoothing_convergence() {
    let mut analyzer = AudioAnalyzer::new(44100);
    let signal = vec![0.5; 576];

    for _ in 0..100 {
        analyzer.analyze(&signal);
    }

    let frame = analyzer.analyze(&signal);

    // After many frames, bass_att should be close to bass
    assert!((frame.bass_att - frame.bass).abs() < 0.2);
}

#[test]
fn test_reset() {
    let mut analyzer = AudioAnalyzer::new(44100);
    let tone = vec![0.5; 576];

    for _ in 0..10 {
        analyzer.analyze(&tone);
    }

    analyzer.reset();

    let silence = vec![0.0; 576];
    let frame = analyzer.analyze(&silence);

    assert!(frame.bass < 0.01);
    assert!(frame.mid < 0.01);
    assert!(frame.treb < 0.01);
}

#[test]
fn test_no_nan_or_infinity() {
    let mut analyzer = AudioAnalyzer::new(44100);

    let test_cases = vec![
        vec![0.0; 576],
        vec![1.0; 576],
        vec![-1.0; 576],
        sine_wave(20.0, 44100.0, 576),
        sine_wave(20000.0, 44100.0, 576),
    ];

    for samples in test_cases {
        let frame = analyzer.analyze(&samples);

        assert!(frame.bass.is_finite());
        assert!(frame.mid.is_finite());
        assert!(frame.treb.is_finite());
        assert!(frame.bass_att.is_finite());
        assert!(frame.mid_att.is_finite());
        assert!(frame.treb_att.is_finite());
    }
}

