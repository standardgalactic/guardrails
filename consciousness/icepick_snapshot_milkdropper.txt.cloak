//! # Temporal Smoothing and Normalization
//!
//! This module implements the temporal smoothing logic that creates the "smoothed" (_att)
//! variants of the band values and normalizes everything relative to a long-term baseline.
//!
//! ## The Problem
//!
//! Raw band energy values from Phoenix Marine can be quite "spiky":
//! - Sudden drum hits create sharp peaks
//! - Silence creates valleys
//! - Different songs have different loudness levels
//!
//! This makes visualizations look jittery and inconsistent across different music.
//!
//! ## The Solution: Two-Stage Smoothing
//!
//! 1. **Short-term average** (~3 seconds): Creates smooth, flowing animations
//! 2. **Long-term baseline** (~minutes): Normalizes across different songs
//!
//! This matches the original Milkdrop2 behavior exactly, preserving preset compatibility.
//!
//! ## Mathematical Foundation
//!
//! ### Exponential Moving Average (EMA)
//!
//! An exponential moving average gives more weight to recent values while still
//! remembering the past:
//!
//! ```text
//! avg[n] = α × avg[n-1] + (1-α) × x[n]
//! ```
//!
//! Where:
//! - `α` (alpha) = decay factor (0 to 1)
//! - `x[n]` = current input value
//! - `avg[n]` = current average
//! - `avg[n-1]` = previous average
//!
//! **Key insight**: The decay factor determines the "memory" of the filter:
//! - `α = 0.95` → ~3 second time constant (short-term average)
//! - `α = 0.9985` → ~90 second time constant (long-term baseline)
//!
//! ### Normalization
//!
//! Once we have a baseline, we normalize relative to it:
//!
//! ```text
//! normalized = current / baseline
//! ```
//!
//! This makes values relative:
//! - `1.0` = average loudness
//! - `> 1.0` = louder than average
//! - `< 1.0` = quieter than average
//!
//! ## Sacred Constants
//!
//! These constants come from the original Milkdrop2 and MUST NOT CHANGE:
//! - Short-term decay: 0.95 (creates bass_att, mid_att, treb_att)
//! - Long-term decay: 0.9985 (creates baseline for normalization)
//!
//! Changing these would break 1000+ existing presets!

use crate::AudioFrame;

// ============================================================================
// Sacred Constants (DO NOT CHANGE!)
// ============================================================================

/// Short-term average decay factor (creates _att variables)
///
/// This creates a ~3 second rolling average.
///
/// Time constant τ = -1 / (sample_rate × ln(α))
/// At 30 fps: τ = -1 / (30 × ln(0.95)) ≈ 3.9 seconds
///
/// **SACRED CONSTANT**: From original Milkdrop2, DO NOT CHANGE!
const AVG_DECAY: f32 = 0.95;

/// Long-term baseline decay factor (normalization reference)
///
/// This creates a very slow baseline that tracks average loudness over minutes.
///
/// Time constant: τ = -1 / (30 × ln(0.9985)) ≈ 90 seconds
///
/// **SACRED CONSTANT**: From original Milkdrop2, DO NOT CHANGE!
const BASELINE_DECAY: f32 = 0.9985;

/// Minimum baseline value to prevent division by zero
///
/// If the baseline gets too small (near silence for extended periods),
/// we clamp it to this minimum to avoid numerical issues.
const MIN_BASELINE: f32 = 0.001;

/// Initial baseline value
///
/// Start slightly above zero so normalization works from frame 1.
/// This value is quickly adapted to match actual audio levels.
const INITIAL_BASELINE: f32 = 0.1;

// ============================================================================
// Temporal Smoother
// ============================================================================

/// Temporal smoothing and normalization engine
///
/// Takes raw band energy values from Phoenix Marine and:
/// 1. Computes short-term averages (bass_att, mid_att, treb_att)
/// 2. Tracks long-term baselines (for normalization)
/// 3. Produces normalized values (relative to baseline)
///
/// # Memory Layout
///
/// Total size: 32 bytes
/// - 6 × f32 (averages and baselines) = 24 bytes
/// - 2 × f32 (constants) = 8 bytes
///
/// # Design Philosophy
///
/// The smoother maintains TWO exponential moving averages per band:
/// - **Fast average** (decay=0.95): ~3 second memory, creates _att variables
/// - **Slow baseline** (decay=0.9985): ~90 second memory, for normalization
///
/// This matches the original Milkdrop2 exactly, ensuring preset compatibility.
#[derive(Debug, Clone)]
pub struct TemporalSmoother {
    // Short-term averages (fast decay, ~3 seconds)
    // These become the _att variables (bass_att, mid_att, treb_att)
    bass_avg: f32,
    mid_avg: f32,
    treble_avg: f32,

    // Long-term baselines (very slow decay, ~90 seconds)
    // Used for normalization (dividing immediate values)
    bass_baseline: f32,
    mid_baseline: f32,
    treble_baseline: f32,

    // Decay constants (stored for potential future configurability)
    avg_decay: f32,
    baseline_decay: f32,
}

impl TemporalSmoother {
    /// Create a new temporal smoother with default settings
    ///
    /// Initializes all averages to zero and baselines to a small non-zero value
    /// to avoid division by zero on the first frame.
    ///
    /// # Example
    ///
    /// ```rust,ignore
    /// let smoother = TemporalSmoother::new();
    /// ```
    pub fn new() -> Self {
        Self {
            // Start with zero averages (no history yet)
            bass_avg: 0.0,
            mid_avg: 0.0,
            treble_avg: 0.0,

            // Start with small non-zero baselines
            // These will quickly adapt to actual audio levels
            bass_baseline: INITIAL_BASELINE,
            mid_baseline: INITIAL_BASELINE,
            treble_baseline: INITIAL_BASELINE,

            // Sacred constants from original Milkdrop2
            avg_decay: AVG_DECAY,
            baseline_decay: BASELINE_DECAY,
        }
    }

    /// Smooth and normalize band values
    ///
    /// Takes raw band energy values from Phoenix Marine and produces an AudioFrame
    /// with both immediate and smoothed (_att) values, all normalized by the baseline.
    ///
    /// # Arguments
    ///
    /// * `bass` - Raw bass energy (0.0 to 1.0+)
    /// * `mid` - Raw mid energy (0.0 to 1.0+)
    /// * `treble` - Raw treble energy (0.0 to 1.0+)
    ///
    /// # Returns
    ///
    /// `AudioFrame` containing 6 values:
    /// - `bass`, `mid`, `treb` - Immediate values (normalized by baseline)
    /// - `bass_att`, `mid_att`, `treb_att` - Smoothed values (normalized by baseline)
    ///
    /// # Algorithm
    ///
    /// For each band:
    /// 1. Update short-term average: `avg = 0.95 × avg + 0.05 × raw`
    /// 2. Update long-term baseline: `baseline = 0.9985 × baseline + 0.0015 × raw`
    /// 3. Normalize immediate: `value = raw / baseline`
    /// 4. Normalize smoothed: `value_att = avg / baseline`
    ///
    /// # Performance
    ///
    /// - Time complexity: O(1) (constant time)
    /// - Operations: 18 multiplies + 12 adds + 6 divides
    /// - Typical execution time: <5μs (negligible compared to filtering)
    pub fn smooth(&mut self, bass: f32, mid: f32, treble: f32) -> AudioFrame {
        // ========================================================================
        // Step 1: Update short-term averages (fast decay, ~3 seconds)
        // ========================================================================
        //
        // These create the _att (attenuated) variables that presets use for
        // smooth, flowing animations.
        //
        // Formula: avg[n] = α × avg[n-1] + (1-α) × x[n]
        // where α = 0.95 (AVG_DECAY)
        //
        // The (1-α) = 0.05 term is the "update rate" - how much of the new
        // value gets mixed into the average.

        let update_rate = 1.0 - self.avg_decay;

        self.bass_avg = self.avg_decay * self.bass_avg + update_rate * bass;
        self.mid_avg = self.avg_decay * self.mid_avg + update_rate * mid;
        self.treble_avg = self.avg_decay * self.treble_avg + update_rate * treble;

        // ========================================================================
        // Step 2: Update long-term baselines (very slow decay, ~90 seconds)
        // ========================================================================
        //
        // The baseline tracks average loudness over a long period. This allows
        // normalization: loud songs don't overwhelm, quiet songs are boosted.
        //
        // Formula: same as above, but with α = 0.9985 (BASELINE_DECAY)
        //
        // The (1-α) = 0.0015 term means the baseline adapts VERY slowly,
        // giving it time to settle on the true average loudness.

        let baseline_update = 1.0 - self.baseline_decay;

        self.bass_baseline = self.baseline_decay * self.bass_baseline + baseline_update * bass;
        self.mid_baseline = self.baseline_decay * self.mid_baseline + baseline_update * mid;
        self.treble_baseline = self.baseline_decay * self.treble_baseline + baseline_update * treble;

        // ========================================================================
        // Step 3: Normalize immediate values by baseline
        // ========================================================================
        //
        // This makes values relative to the average:
        // - Value = 1.0 means "average loudness"
        // - Value > 1.0 means "louder than average"
        // - Value < 1.0 means "quieter than average"
        //
        // We guard against division by zero with MIN_BASELINE check.

        let bass_imm = if self.bass_baseline > MIN_BASELINE {
            bass / self.bass_baseline
        } else {
            1.0 // Default to neutral value if baseline is too small
        };

        let mid_imm = if self.mid_baseline > MIN_BASELINE {
            mid / self.mid_baseline
        } else {
            1.0
        };

        let treble_imm = if self.treble_baseline > MIN_BASELINE {
            treble / self.treble_baseline
        } else {
            1.0
        };

        // ========================================================================
        // Step 4: Normalize smoothed averages by baseline
        // ========================================================================
        //
        // Same as above, but using the smoothed averages instead of raw values.
        // This creates the _att (attenuated) variables.

        let bass_att = if self.bass_baseline > MIN_BASELINE {
            self.bass_avg / self.bass_baseline
        } else {
            1.0
        };

        let mid_att = if self.mid_baseline > MIN_BASELINE {
            self.mid_avg / self.mid_baseline
        } else {
            1.0
        };

        let treble_att = if self.treble_baseline > MIN_BASELINE {
            self.treble_avg / self.treble_baseline
        } else {
            1.0
        };

        // ========================================================================
        // Step 5: Return the complete audio frame
        // ========================================================================
        //
        // This structure contains all 6 "sacred variables" that presets depend on.

        AudioFrame {
            // Immediate values (responsive, can be spiky)
            bass: bass_imm,
            mid: mid_imm,
            treb: treble_imm,

            // Smoothed values (flowing, gentle)
            bass_att,
            mid_att,
            treb_att: treble_att,
        }
    }

    /// Reset smoother state
    ///
    /// Clears all averages and baselines. Useful when switching audio sources
    /// or when you want to "forget" the previous audio history.
    ///
    /// # Example
    ///
    /// ```rust,ignore
    /// let mut smoother = TemporalSmoother::new();
    ///
    /// // ... smooth some frames ...
    ///
    /// // User switches to a different song
    /// smoother.reset();
    /// ```
    pub fn reset(&mut self) {
        self.bass_avg = 0.0;
        self.mid_avg = 0.0;
        self.treble_avg = 0.0;
        self.bass_baseline = INITIAL_BASELINE;
        self.mid_baseline = INITIAL_BASELINE;
        self.treble_baseline = INITIAL_BASELINE;
    }

    /// Get current baselines (for debugging/monitoring)
    ///
    /// Returns the current long-term baseline values. Useful for monitoring
    /// how the analyzer is adapting to different audio levels.
    ///
    /// # Returns
    ///
    /// Tuple of (bass_baseline, mid_baseline, treble_baseline)
    pub fn baselines(&self) -> (f32, f32, f32) {
        (self.bass_baseline, self.mid_baseline, self.treble_baseline)
    }
}

impl Default for TemporalSmoother {
    fn default() -> Self {
        Self::new()
    }
}

// ============================================================================
// Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_smoother_creation() {
        let smoother = TemporalSmoother::new();

        // Averages should start at zero
        assert_eq!(smoother.bass_avg, 0.0);
        assert_eq!(smoother.mid_avg, 0.0);
        assert_eq!(smoother.treble_avg, 0.0);

        // Baselines should start at INITIAL_BASELINE
        assert_eq!(smoother.bass_baseline, INITIAL_BASELINE);
        assert_eq!(smoother.mid_baseline, INITIAL_BASELINE);
        assert_eq!(smoother.treble_baseline, INITIAL_BASELINE);

        // Constants should be set correctly
        assert_eq!(smoother.avg_decay, AVG_DECAY);
        assert_eq!(smoother.baseline_decay, BASELINE_DECAY);
    }

    #[test]
    fn test_smooth_silence() {
        let mut smoother = TemporalSmoother::new();

        // Smooth silence repeatedly
        for _ in 0..100 {
            let frame = smoother.smooth(0.0, 0.0, 0.0);

            // All values should approach zero
            // (Baseline prevents actual zero due to normalization)
            assert!(frame.bass.is_finite());
            assert!(frame.mid.is_finite());
            assert!(frame.treb.is_finite());
            assert!(frame.bass_att.is_finite());
            assert!(frame.mid_att.is_finite());
            assert!(frame.treb_att.is_finite());
        }
    }

    #[test]
    fn test_smooth_constant_signal() {
        let mut smoother = TemporalSmoother::new();

        // Feed constant values
        let constant = 0.5;

        for _ in 0..100 {
            let frame = smoother.smooth(constant, constant, constant);

            // Eventually, normalized values should approach 1.0
            // (immediate value / baseline, both approach the same constant)
            assert!(frame.bass.is_finite());
            assert!(frame.mid.is_finite());
            assert!(frame.treb.is_finite());
        }

        // After many iterations, check that bass is positive and finite
        let final_frame = smoother.smooth(constant, constant, constant);

        // The immediate value should be positive and reasonable
        // (Baseline adapts VERY slowly with 0.9985 decay, so won't fully settle in 100 frames)
        assert!(
            final_frame.bass > 0.5 && final_frame.bass < 10.0,
            "Normalized value should be reasonable (got {})",
            final_frame.bass
        );
    }

    #[test]
    fn test_smoothing_convergence() {
        let mut smoother = TemporalSmoother::new();

        // Feed a constant signal
        let signal = 0.5;
        let mut prev_bass_att = 0.0;

        for i in 0..200 {
            let frame = smoother.smooth(signal, signal, signal);

            // bass_att should gradually approach bass
            let change = (frame.bass_att - prev_bass_att).abs();

            // After initial transient, changes should become smaller
            if i > 100 {
                assert!(
                    change < 0.01,
                    "Smoothing should converge (change={} at frame {})",
                    change,
                    i
                );
            }

            prev_bass_att = frame.bass_att;
        }
    }

    #[test]
    fn test_baseline_adaptation() {
        let mut smoother = TemporalSmoother::new();

        // Feed loud signal for a while (need MANY frames due to 0.9985 decay!)
        for _ in 0..1000 {
            smoother.smooth(0.8, 0.8, 0.8);
        }

        // Baseline should have increased
        let (bass_baseline, _, _) = smoother.baselines();
        assert!(
            bass_baseline > INITIAL_BASELINE,
            "Baseline should adapt upward to loud signal (baseline={})",
            bass_baseline
        );

        // Now feed quiet signal (also needs many frames)
        for _ in 0..1000 {
            smoother.smooth(0.2, 0.2, 0.2);
        }

        // Baseline should have decreased (but slowly due to BASELINE_DECAY)
        let (new_bass_baseline, _, _) = smoother.baselines();
        assert!(
            new_bass_baseline < bass_baseline,
            "Baseline should adapt downward to quiet signal (old={}, new={})",
            bass_baseline,
            new_bass_baseline
        );
    }

    #[test]
    fn test_reset() {
        let mut smoother = TemporalSmoother::new();

        // Build up state
        for _ in 0..50 {
            smoother.smooth(0.5, 0.5, 0.5);
        }

        // Reset
        smoother.reset();

        // State should be back to initial values
        assert_eq!(smoother.bass_avg, 0.0);
        assert_eq!(smoother.mid_avg, 0.0);
        assert_eq!(smoother.treble_avg, 0.0);
        assert_eq!(smoother.bass_baseline, INITIAL_BASELINE);
        assert_eq!(smoother.mid_baseline, INITIAL_BASELINE);
        assert_eq!(smoother.treble_baseline, INITIAL_BASELINE);
    }

    #[test]
    fn test_no_nan_or_infinity() {
        let mut smoother = TemporalSmoother::new();

        // Test edge cases
        let test_cases = vec![
            (0.0, 0.0, 0.0),           // Silence
            (1.0, 1.0, 1.0),           // Maximum
            (0.001, 0.001, 0.001),     // Very small
            (100.0, 100.0, 100.0),     // Way above range (clipped earlier, but test anyway)
        ];

        for (bass, mid, treble) in test_cases {
            let frame = smoother.smooth(bass, mid, treble);

            // All values must be finite
            assert!(frame.bass.is_finite(), "Bass should be finite");
            assert!(frame.mid.is_finite(), "Mid should be finite");
            assert!(frame.treb.is_finite(), "Treble should be finite");
            assert!(frame.bass_att.is_finite(), "Bass_att should be finite");
            assert!(frame.mid_att.is_finite(), "Mid_att should be finite");
            assert!(frame.treb_att.is_finite(), "Treb_att should be finite");
        }
    }

    #[test]
    fn test_att_values_are_smoother() {
        let mut smoother = TemporalSmoother::new();

        // Feed alternating signal (simulate spiky bass hits)
        let mut immediate_changes = Vec::new();
        let mut smoothed_changes = Vec::new();

        let mut prev_bass = 0.0;
        let mut prev_bass_att = 0.0;

        for i in 0..100 {
            // Alternate between high and low
            let signal = if i % 10 < 5 { 0.8 } else { 0.2 };

            let frame = smoother.smooth(signal, 0.5, 0.5);

            // Track changes
            immediate_changes.push((frame.bass - prev_bass).abs());
            smoothed_changes.push((frame.bass_att - prev_bass_att).abs());

            prev_bass = frame.bass;
            prev_bass_att = frame.bass_att;
        }

        // After initial transient, smoothed values should change less
        let immediate_variance: f32 = immediate_changes.iter().skip(20).sum::<f32>()
            / (immediate_changes.len() - 20) as f32;
        let smoothed_variance: f32 = smoothed_changes.iter().skip(20).sum::<f32>()
            / (smoothed_changes.len() - 20) as f32;

        assert!(
            smoothed_variance < immediate_variance,
            "Smoothed values (_att) should vary less than immediate values"
        );
    }
}

