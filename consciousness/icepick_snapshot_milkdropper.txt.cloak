----- FILE: ./crates/milkdropper-preset/src/parser.rs -----
//! .milk file parser.
//!
//! This module parses .milk preset files (INI-style format) and compiles
//! the expressions into bytecode.
//!
//! ## File Format
//!
//! ```ini
//! [preset00]
//! fRating=3.000000
//! zoom=1.000000
//! rot=0.000000
//! per_frame_1=wave_r = wave_r + 0.4*sin(time);
//! per_frame_2=zoom = zoom + bass * 0.1;
//! ```

use std::collections::BTreeMap;
use std::fs;
use std::path::Path;

use crate::error::PresetError;
use crate::eval::{Compiler, Parser as ExprParser};
use crate::preset::Preset;

/// Parse a .milk preset file.
///
/// This is the main entry point for loading presets.
///
/// ```no_run
/// use milkdropper_preset::parser::parse_preset_file;
///
/// let preset = parse_preset_file("presets/example.milk").unwrap();
/// println!("Loaded preset: {}", preset.name);
/// println!("Per-frame expressions: {}", preset.per_frame_count());
/// ```
pub fn parse_preset_file(path: impl AsRef<Path>) -> Result<Preset, PresetError> {
    let path = path.as_ref();

    // Read file
    let content = fs::read_to_string(path)?;

    // Extract preset name from filename
    let name = path
        .file_stem()
        .and_then(|s| s.to_str())
        .unwrap_or("Unknown")
        .to_string();

    // Parse content
    parse_preset_content(&content, name)
}

/// Parse preset content from a string.
///
/// This is useful for testing or loading presets from non-file sources.
pub fn parse_preset_content(content: &str, name: String) -> Result<Preset, PresetError> {
    let mut preset = Preset::new(name);

    // Find [preset00] section
    let mut in_preset_section = false;
    let mut per_frame_exprs = BTreeMap::new(); // Sorted by number

    for line in content.lines() {
        let line = line.trim();

        // Skip empty lines and comments
        if line.is_empty() || line.starts_with('#') || line.starts_with("//") {
            continue;
        }

        // Check for section header
        if line.starts_with('[') {
            in_preset_section = line.to_lowercase().contains("preset");
            continue;
        }

        // Only parse lines inside preset section
        if !in_preset_section {
            continue;
        }

        // Parse key=value
        let (key, value) = parse_line(line)?;

        // Check if it's a per-frame expression
        if key.starts_with("per_frame_") {
            let (num, expr) = parse_per_frame(&key, &value)?;
            per_frame_exprs.insert(num, expr);
        } else {
            // Special handling for rating (before moving the value)
            if key == "fRating" {
                if let Ok(rating) = value.parse::<f32>() {
                    preset.rating = rating;
                }
            }

            // Regular parameter
            preset.set_param(key, value);
        }
    }

    // Compile per-frame expressions in sorted order
    let compiler = Compiler::new();
    for (_num, expr_text) in per_frame_exprs {
        // Parse expression
        let mut expr_parser = ExprParser::from_str(&expr_text);
        let ast = expr_parser.parse().map_err(|e| {
            PresetError::Compile(format!("Failed to parse expression '{}': {}", expr_text, e))
        })?;

        // Compile to bytecode
        let program = compiler.compile_with_source(&ast, expr_text.clone())?;

        preset.add_per_frame(program);
    }

    Ok(preset)
}

/// Parse a single line: `key=value`.
///
/// Returns (key, value) as strings.
fn parse_line(line: &str) -> Result<(String, String), PresetError> {
    let parts: Vec<&str> = line.splitn(2, '=').collect();
    if parts.len() != 2 {
        return Err(PresetError::Format(format!(
            "Invalid line (expected key=value): {}",
            line
        )));
    }

    let key = parts[0].trim().to_string();
    let value = parts[1].trim().to_string();

    Ok((key, value))
}

/// Parse a per-frame expression line.
///
/// Input: `per_frame_1`, `wave_r = wave_r + 0.4*sin(time);`
/// Output: (1, `wave_r = wave_r + 0.4*sin(time)`)
fn parse_per_frame(key: &str, value: &str) -> Result<(usize, String), PresetError> {
    // Extract number from "per_frame_N"
    let num_str = key.strip_prefix("per_frame_").ok_or_else(|| {
        PresetError::Format(format!("Invalid per-frame key: {}", key))
    })?;

    let num = num_str.parse::<usize>().map_err(|_| {
        PresetError::Format(format!("Invalid per-frame number: {}", num_str))
    })?;

    // Clean up expression (remove trailing semicolon if present)
    let expr = value.trim_end_matches(';').trim().to_string();

    Ok((num, expr))
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_parse_line() {
        let (key, value) = parse_line("zoom=1.5").unwrap();
        assert_eq!(key, "zoom");
        assert_eq!(value, "1.5");

        let (key, value) = parse_line("  nWaveMode  =  3  ").unwrap();
        assert_eq!(key, "nWaveMode");
        assert_eq!(value, "3");
    }

    #[test]
    fn test_parse_line_invalid() {
        assert!(parse_line("invalid line").is_err());
        assert!(parse_line("no equals sign here").is_err());
    }

    #[test]
    fn test_parse_per_frame() {
        let (num, expr) = parse_per_frame("per_frame_1", "zoom = 1.0 + bass;").unwrap();
        assert_eq!(num, 1);
        assert_eq!(expr, "zoom = 1.0 + bass");

        let (num, expr) = parse_per_frame("per_frame_42", "q1 = sin(time)").unwrap();
        assert_eq!(num, 42);
        assert_eq!(expr, "q1 = sin(time)");
    }

    #[test]
    fn test_parse_preset_content() {
        let content = r#"
[preset00]
fRating=4.000000
zoom=1.000000
rot=0.000000
per_frame_1=wave_r = wave_r + 0.4*sin(time);
per_frame_2=zoom = zoom + bass * 0.1;
"#;

        let preset = parse_preset_content(content, "Test".to_string()).unwrap();

        assert_eq!(preset.name, "Test");
        assert_eq!(preset.rating, 4.0);
        assert_eq!(preset.get_float("zoom"), Some(1.0));
        assert_eq!(preset.per_frame_count(), 2);
    }

    #[test]
    fn test_parse_preset_with_comments() {
        let content = r#"
# This is a comment
[preset00]
// Another comment
fRating=3.5

# Parameter
zoom=1.2

per_frame_1=q1 = bass;
"#;

        let preset = parse_preset_content(content, "Test".to_string()).unwrap();

        assert_eq!(preset.rating, 3.5);
        assert_eq!(preset.get_float("zoom"), Some(1.2));
        assert_eq!(preset.per_frame_count(), 1);
    }

    #[test]
    fn test_parse_preset_empty() {
        let content = "[preset00]\n";
        let preset = parse_preset_content(content, "Empty".to_string()).unwrap();

        assert_eq!(preset.name, "Empty");
        assert_eq!(preset.per_frame_count(), 0);
    }

    #[test]
    fn test_parse_preset_invalid_expression() {
        let content = r#"
[preset00]
per_frame_1=invalid syntax here!!!;
"#;

        // Should fail to parse the invalid expression
        assert!(parse_preset_content(content, "Test".to_string()).is_err());
    }
}

----- END FILE: ./crates/milkdropper-preset/src/parser.rs -----


----- FILE: ./crates/milkdropper-preset/src/preset.rs -----
//! Preset structure and metadata.
//!
//! This module defines the Preset type which represents a loaded .milk preset
//! with all its parameters, compiled expressions, and metadata.

use crate::eval::bytecode::Program;
use std::collections::HashMap;

/// A compiled preset ready for execution.
///
/// This contains all the data loaded from a .milk file:
/// - Numeric parameters (zoom, rot, etc.)
/// - Compiled per-frame expressions (bytecode programs)
/// - Metadata (rating, description, etc.)
#[derive(Debug, Clone)]
pub struct Preset {
    /// Preset name (usually filename without extension)
    pub name: String,

    /// User rating (0.0-5.0)
    pub rating: f32,

    /// Raw parameters as key-value pairs
    ///
    /// This includes all numeric parameters from the .milk file:
    /// - fGammaAdj, fVideoEchoZoom, etc.
    /// - nWaveMode, nVideoEchoOrientation, etc.
    /// - bAdditiveWaves, etc.
    ///
    /// We store them as strings and parse on-demand for flexibility.
    pub params: HashMap<String, String>,

    /// Compiled per-frame expressions (executed every frame)
    ///
    /// These are the expressions from `per_frame_N=...` lines,
    /// compiled into bytecode for fast execution.
    pub per_frame: Vec<Program>,

    // Phase 2: Per-pixel expressions, init expressions, shaders
    // pub per_pixel: Vec<Program>,
    // pub init: Vec<Program>,
    // pub shaders: Vec<ShaderCode>,
}

impl Preset {
    /// Create a new empty preset.
    pub fn new(name: String) -> Self {
        Self {
            name,
            rating: 3.0,
            params: HashMap::new(),
            per_frame: Vec::new(),
        }
    }

    /// Get a parameter value as a float.
    ///
    /// Returns None if the parameter doesn't exist or can't be parsed.
    pub fn get_float(&self, key: &str) -> Option<f32> {
        self.params.get(key)?.parse().ok()
    }

    /// Get a parameter value as an integer.
    ///
    /// Returns None if the parameter doesn't exist or can't be parsed.
    pub fn get_int(&self, key: &str) -> Option<i32> {
        self.params.get(key)?.parse().ok()
    }

    /// Get a parameter value as a boolean (0/1).
    ///
    /// Returns None if the parameter doesn't exist or can't be parsed.
    pub fn get_bool(&self, key: &str) -> Option<bool> {
        match self.params.get(key)?.as_str() {
            "0" => Some(false),
            "1" => Some(true),
            _ => None,
        }
    }

    /// Set a parameter value.
    pub fn set_param(&mut self, key: String, value: String) {
        self.params.insert(key, value);
    }

    /// Add a compiled per-frame expression.
    pub fn add_per_frame(&mut self, program: Program) {
        self.per_frame.push(program);
    }

    /// Get the number of per-frame expressions.
    pub fn per_frame_count(&self) -> usize {
        self.per_frame.len()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_preset_creation() {
        let preset = Preset::new("Test Preset".to_string());
        assert_eq!(preset.name, "Test Preset");
        assert_eq!(preset.rating, 3.0);
        assert!(preset.params.is_empty());
        assert!(preset.per_frame.is_empty());
    }

    #[test]
    fn test_get_float() {
        let mut preset = Preset::new("Test".to_string());
        preset.set_param("zoom".to_string(), "1.5".to_string());

        assert_eq!(preset.get_float("zoom"), Some(1.5));
        assert_eq!(preset.get_float("nonexistent"), None);
    }

    #[test]
    fn test_get_int() {
        let mut preset = Preset::new("Test".to_string());
        preset.set_param("nWaveMode".to_string(), "3".to_string());

        assert_eq!(preset.get_int("nWaveMode"), Some(3));
        assert_eq!(preset.get_int("nonexistent"), None);
    }

    #[test]
    fn test_get_bool() {
        let mut preset = Preset::new("Test".to_string());
        preset.set_param("bAdditiveWaves".to_string(), "1".to_string());
        preset.set_param("bOtherFlag".to_string(), "0".to_string());

        assert_eq!(preset.get_bool("bAdditiveWaves"), Some(true));
        assert_eq!(preset.get_bool("bOtherFlag"), Some(false));
        assert_eq!(preset.get_bool("nonexistent"), None);
    }
}

