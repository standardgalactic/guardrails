64, 7696, 777, 3109, 281, 2183, 12, 40827, 11, 51687], "temperature": 0.0, "avg_logprob": -0.15708707173665365, "compression_ratio": 1.5258064516129033, "no_speech_prob": 3.559201978281523e-12}, {"id": 55, "seek": 21556, "start": 242.0, "end": 245.0, "text": " managed through a feature called the Performance Patch.", "tokens": [51687, 6453, 807, 257, 4111, 1219, 264, 25047, 44359, 13, 51837], "temperature": 0.0, "avg_logprob": -0.15708707173665365, "compression_ratio": 1.5258064516129033, "no_speech_prob": 3.559201978281523e-12}, {"id": 56, "seek": 24500, "start": 245.0, "end": 248.7, "text": " Creating a standard digital recording is like trying to unbake a cake.", "tokens": [50365, 40002, 257, 3832, 4562, 6613, 307, 411, 1382, 281, 517, 65, 619, 257, 5908, 13, 50550], "temperature": 0.0, "avg_logprob": -0.10487676780914591, "compression_ratio": 1.6140939597315436, "no_speech_prob": 5.0584549569909765e-12}, {"id": 57, "seek": 24500, "start": 248.7, "end": 251.92, "text": " The sounds are permanently mixed together in that rigid grid.", "tokens": [50550, 440, 3263, 366, 24042, 7467, 1214, 294, 300, 22195, 10748, 13, 50711], "temperature": 0.0, "avg_logprob": -0.10487676780914591, "compression_ratio": 1.6140939597315436, "no_speech_prob": 5.0584549569909765e-12}, {"id": 58, "seek": 24500, "start": 251.92, "end": 256.82, "text": " But an 8A file keeps the musical elements isolated and mathematically distinct.", "tokens": [50711, 583, 364, 1649, 32, 3991, 5965, 264, 9165, 4959, 14621, 293, 44003, 10644, 13, 50956], "temperature": 0.0, "avg_logprob": -0.10487676780914591, "compression_ratio": 1.6140939597315436, "no_speech_prob": 5.0584549569909765e-12}, {"id": 59, "seek": 24500, "start": 256.82, "end": 260.22, "text": " This interface shows how an artist interacts with the format.", "tokens": [50956, 639, 9226, 3110, 577, 364, 5748, 43582, 365, 264, 7877, 13, 51126], "temperature": 0.0, "avg_logprob": -0.10487676780914591, "compression_ratio": 1.6140939597315436, "no_speech_prob": 5.0584549569909765e-12}, {"id": 60, "seek": 24500, "start": 260.22, "end": 265.12, "text": " Instead of destructive equalization or filtering, they can open the dehydrated file and adjust", "tokens": [51126, 7156, 295, 26960, 2681, 2144, 420, 30822, 11, 436, 393, 1269, 264, 32102, 5468, 3991, 293, 4369, 51371], "temperature": 0.0, "avg_logprob": -0.10487676780914591, "compression_ratio": 1.6140939597315436, "no_speech_prob": 5.0584549569909765e-12}, {"id": 61, "seek": 24500, "start": 265.12, "end": 266.7, "text": " isolated variables.", "tokens": [51371, 14621, 9102, 13, 51450], "temperature": 0.0, "avg_logprob": -0.10487676780914591, "compression_ratio": 1.6140939597315436, "no_speech_prob": 5.0584549569909765e-12}, {"id": 62, "seek": 24500, "start": 266.7, "end": 271.66, "text": " They can increase vocal vibrato intensity, or add weight to the harmonics of a piano chord.", "tokens": [51450, 814, 393, 3488, 11657, 11599, 2513, 13749, 11, 420, 909, 3364, 281, 264, 14750, 1167, 295, 257, 9211, 14137, 13, 51698], "temperature": 0.0, "avg_logprob": -0.10487676780914591, "compression_ratio": 1.6140939597315436, "no_speech_prob": 5.0584549569909765e-12}, {"id": 63, "seek": 27166, "start": 271.66, "end": 274.32000000000005, "text": " All without degrading the original master data.", "tokens": [50365, 1057, 1553, 24740, 278, 264, 3380, 4505, 1412, 13, 50498], "temperature": 0.0, "avg_logprob": -0.08174574564373682, "compression_ratio": 1.52020202020202, "no_speech_prob": 3.848373876513822e-12}, {"id": 64, "seek": 27166, "start": 274.32000000000005, "end": 278.92, "text": " By maintaining complete control over the underlying mathematics, the format ensures that the original", "tokens": [50498, 3146, 14916, 3566, 1969, 670, 264, 14217, 18666, 11, 264, 7877, 28111, 300, 264, 3380, 50728], "temperature": 0.0, "avg_logprob": -0.08174574564373682, "compression_ratio": 1.52020202020202, "no_speech_prob": 3.848373876513822e-12}, {"id": 65, "seek": 27166, "start": 278.92, "end": 283.84000000000003, "text": " physical energy of the room\u2014the air pressure that actually drives a speaker cone\u2014is preserved", "tokens": [50728, 4001, 2281, 295, 264, 1808, 2958, 3322, 1988, 3321, 300, 767, 11754, 257, 8145, 19749, 2958, 271, 22242, 50974], "temperature": 0.0, "avg_logprob": -0.08174574564373682, "compression_ratio": 1.52020202020202, "no_speech_prob": 3.848373876513822e-12}, {"id": 66, "seek": 27166, "start": 283.84000000000003, "end": 287.28000000000003, "text": " exactly as it occurred, even decades into the future.", "tokens": [50974, 2293, 382, 309, 11068, 11, 754, 7878, 666, 264, 2027, 13, 51146], "temperature": 0.0, "avg_logprob": -0.08174574564373682, "compression_ratio": 1.52020202020202, "no_speech_prob": 3.848373876513822e-12}, {"id": 67, "seek": 28728, "start": 287.28, "end": 294.15999999999997, "text": " The Phoenix 8A format captures the living, interactive acoustics of the performance, securing the artist's", "tokens": [50365, 440, 18383, 1649, 32, 7877, 27986, 264, 2647, 11, 15141, 22740, 1167, 295, 264, 3389, 11, 33640, 264, 5748, 311, 50709], "temperature": 0.0, "avg_logprob": -0.1648903279691129, "compression_ratio": 1.2916666666666667, "no_speech_prob": 4.445836927768898e-12}, {"id": 68, "seek": 28728, "start": 294.15999999999997, "end": 297.15999999999997, "text": " exact intent for as long as the music is played.", "tokens": [50709, 1900, 8446, 337, 382, 938, 382, 264, 1318, 307, 3737, 13, 50859], "temperature": 0.0, "avg_logprob": -0.1648903279691129, "compression_ratio": 1.2916666666666667, "no_speech_prob": 4.445836927768898e-12}, {"id": 69, "seek": 29716, "start": 297.16, "end": 304.52000000000004, "text": " The Phoenix 8BP", "tokens": [50365, 440, 18383, 1649, 33, 47, 50733], "temperature": 1.0, "avg_logprob": -2.8941522642623547, "compression_ratio": 1.3035714285714286, "no_speech_prob": 2.8959905654102336e-11}, {"id": 70, "seek": 29716, "start": 304.52000000000004, "end": 306.06, "text": " The 2020", 